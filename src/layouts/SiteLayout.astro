---
import '../styles/global.css';
import { getCollection } from 'astro:content';
import HomeIndexMenu from '../components/HomeIndexMenu.astro';
import { projects } from '../data/projects';
import { siteMeta } from '../data/site';
import { withBase } from '../utils/paths';

interface Props {
  title?: string;
  active?: 'home' | 'articles' | 'series' | 'projects' | 'about';
  description?: string;
}

const {
  title = siteMeta.siteName,
  active = 'home',
  description = siteMeta.siteDescription,
} = Astro.props;

const pageTitle = title === siteMeta.siteName ? title : `${title} | ${siteMeta.siteName}`;

const posts = (await getCollection('posts'))
  .filter((post) => !post.data.draft && !post.data.private)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const searchItems = [
  ...posts.map((post) => ({
    type: '文章',
    title: post.data.title,
    description: post.data.description,
    href: withBase(`/articles/${post.slug}/`),
    keywords: [post.data.category, ...post.data.tags],
  })),
  ...projects.map((project) => ({
    type: '项目',
    title: project.title,
    description: project.description,
    href: project.url ?? withBase('/projects/'),
    keywords: [project.type, ...project.tags],
  })),
];
---

<!doctype html>
<html
  lang="zh-CN"
  data-page-kind={active === 'home' ? 'home' : 'content'}
  data-home-url={withBase('/')}
  data-default-intro-url={withBase('/intro-motion-3/')}
>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" sizes="256x256" href={withBase('/favicon.png?v=4')} />
    <script is:inline>
      (function () {
        try {
          var savedTheme = localStorage.getItem('theme');
          var savedStyleTheme = localStorage.getItem('styleTheme');
          if (savedTheme === 'dark') savedStyleTheme = 'classic';
          if (!['classic', 'index-gradient', 'visual-system'].includes(savedStyleTheme)) savedStyleTheme = '';
          document.documentElement.dataset.theme = savedTheme === 'dark' ? 'dark' : 'light';
          document.documentElement.dataset.styleTheme = savedStyleTheme || 'visual-system';
        } catch (error) {
          document.documentElement.dataset.theme = 'light';
          document.documentElement.dataset.styleTheme = 'visual-system';
        }
      })();
    </script>
    <script is:inline>
      (function () {
        var page = document.documentElement;
        var introPath = page.dataset.defaultIntroUrl;
        var homePath = page.dataset.homeUrl;
        var currentPath = window.location.pathname + window.location.search + window.location.hash;
        var seenKey = 'site-intro-seen-v1';
        var returnKey = 'site-intro-return-v1';
        var internalHomeKey = 'site-intro-internal-home-v1';

        if (!introPath || !homePath) return;

        document.addEventListener('click', function (event) {
          if (event.defaultPrevented || event.button !== 0 || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;

          var link = event.target.closest && event.target.closest('a[href]');
          if (!link || link.target === '_blank' || link.hasAttribute('download')) return;

          var target = new URL(link.href, window.location.origin);
          var homeUrl = new URL(homePath, window.location.origin);
          if (target.origin !== homeUrl.origin || target.pathname !== homeUrl.pathname) return;

          try {
            sessionStorage.setItem(internalHomeKey, String(Date.now()));
          } catch (error) {}
        });

        try {
          var internalHomeAt = Number(sessionStorage.getItem(internalHomeKey));
          if (internalHomeAt) sessionStorage.removeItem(internalHomeKey);

          var returnPath = sessionStorage.getItem(returnKey);
          if (returnPath) sessionStorage.removeItem(returnKey);
          if (returnPath === currentPath) return;

          var isHome = page.dataset.pageKind === 'home';
          var hasSeenIntro = localStorage.getItem(seenKey) === '1';
          var isInternalHomeNavigation = isHome
            && internalHomeAt > 0
            && Date.now() - internalHomeAt < 15000;
          if (isInternalHomeNavigation) return;
          if (!isHome && hasSeenIntro) return;

          var introUrl = new URL(introPath, window.location.origin);
          introUrl.searchParams.set('return', currentPath);
          localStorage.setItem(seenKey, '1');
          sessionStorage.setItem(returnKey, currentPath);
          window.location.replace(introUrl.href);
        } catch (error) {
          // Storage may be unavailable in strict privacy modes. In that case,
          // keep the requested page visible instead of risking a redirect loop.
        }
      })();
    </script>
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <a class="brand" href={withBase('/')} aria-label={`${siteMeta.siteName} 首页`}>
          <span class="brand-mark">C</span>
          <span>{siteMeta.siteName}</span>
        </a>
        <nav class="site-nav" aria-label="主导航">
          <a class:list={[active === 'home' && 'active']} href={withBase('/')}>首页</a>
          <a class:list={[active === 'articles' && 'active']} href={withBase('/articles/')}>文章</a>
          <a class:list={[active === 'series' && 'active']} href={withBase('/series/')}>系列</a>
          <a class:list={[active === 'projects' && 'active']} href={withBase('/projects/')}>项目</a>
          <div class="nav-search" data-site-search data-search-items={JSON.stringify(searchItems)} data-articles-url={withBase('/articles/')}>
            <button class="nav-search-trigger" type="button" aria-label="搜索文章和项目" aria-expanded="false" data-search-toggle>搜索</button>
            <div class="nav-search-panel">
              <input data-search-input type="search" placeholder="搜索文章 / 项目" autocomplete="off" aria-label="搜索文章和项目" />
              <div class="nav-search-results" data-search-results aria-live="polite"></div>
            </div>
          </div>
          <a href={withBase(siteMeta.rssPath)}>RSS</a>
          <a class:list={[active === 'about' && 'active']} href={withBase('/about/')}>关于我</a>
        </nav>
        <div class="header-controls">
          <div class="theme-menu" data-theme-menu>
            <button class="theme-button" type="button" aria-label="选择主题" title="选择主题" aria-expanded="false" data-theme-menu-toggle>
              <span aria-hidden="true">主题</span>
            </button>
            <div class="theme-menu-panel" role="menu">
              <button type="button" role="menuitem" data-theme-option data-style-theme-value="index-gradient" data-theme-value="light">晨曦渐变</button>
              <button type="button" role="menuitem" data-theme-option data-style-theme-value="visual-system" data-theme-value="light">视觉晶蓝</button>
              <button type="button" role="menuitem" data-theme-option data-style-theme-value="classic" data-theme-value="dark">玄墨经典</button>
            </div>
          </div>
          <div class="intro-menu" data-intro-menu>
            <button
              class="intro-button"
              type="button"
              aria-label="选择开屏动画"
              title="选择开屏动画"
              aria-controls="intro-menu-panel"
              aria-expanded="false"
              data-intro-menu-toggle
            >开屏</button>
            <div class="intro-menu-panel" id="intro-menu-panel" role="menu" aria-label="开屏动画方案">
              <button type="button" role="menuitem" data-intro-option data-intro-url={withBase('/intro-motion-2/')}>
                <span class="intro-option-title">液态字场</span>
                <span class="intro-option-note">珠光文字与柔性流场</span>
              </button>
              <button type="button" role="menuitem" data-intro-option data-intro-url={withBase('/intro-motion-3/')}>
                <span class="intro-option-heading">
                  <span class="intro-option-title">天体序章</span>
                  <span class="intro-option-default">默认</span>
                </span>
                <span class="intro-option-note">星轨、日蚀与沉浸光门</span>
              </button>
            </div>
          </div>
          <HomeIndexMenu />
        </div>
      </header>
      <div data-pagefind-body>
        <slot />
      </div>
    </div>
    <script is:inline>
      (function () {
        var themeMenu = document.querySelector('[data-theme-menu]');
        if (!themeMenu) return;

        var themeButton = themeMenu.querySelector('[data-theme-menu-toggle]');
        var themeOptions = themeMenu.querySelectorAll('[data-theme-option]');

        function currentTheme() {
          return document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
        }

        function currentStyleTheme() {
          var styleTheme = document.documentElement.dataset.styleTheme;
          return ['classic', 'index-gradient', 'visual-system'].includes(styleTheme) ? styleTheme : 'visual-system';
        }

        function setOpen(isOpen) {
          if (!themeButton) return;
          themeMenu.classList.toggle('open', isOpen);
          themeButton.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        }

        function updateThemeButton() {
          if (!themeButton) return;
          var themeLabels = {
            'index-gradient': '晨曦渐变',
            'visual-system': '视觉晶蓝',
            dark: '玄墨经典',
          };
          var iconKey = currentTheme() === 'dark' ? 'dark' : currentStyleTheme();
          var label = themeLabels[iconKey] || '视觉晶蓝';
          var mode = currentTheme() === 'dark' ? '深色' : '浅色';
          themeButton.setAttribute('aria-label', '当前主题：' + label + ' ' + mode + '，点击选择主题');
          themeButton.setAttribute('title', '当前主题：' + label + ' ' + mode);
        }

        updateThemeButton();

        themeButton.addEventListener('click', function () {
          setOpen(!themeMenu.classList.contains('open'));
        });

        themeOptions.forEach(function (option) {
          option.addEventListener('click', function () {
            var nextStyleTheme = option.getAttribute('data-style-theme-value') || 'visual-system';
            var nextTheme = option.getAttribute('data-theme-value') || 'light';
            document.documentElement.dataset.styleTheme = nextStyleTheme;
            document.documentElement.dataset.theme = nextTheme;
            updateThemeButton();
            setOpen(false);
            try {
              localStorage.setItem('styleTheme', nextStyleTheme);
              localStorage.setItem('theme', nextTheme);
            } catch (error) {}
          });
        });

        document.addEventListener('keydown', function (event) {
          if (event.key === 'Escape') setOpen(false);
        });

        document.addEventListener('click', function (event) {
          if (!themeMenu.contains(event.target)) setOpen(false);
        });
      })();
    </script>
    <script is:inline>
      (function () {
        var introMenu = document.querySelector('[data-intro-menu]');
        if (!introMenu) return;

        var introButton = introMenu.querySelector('[data-intro-menu-toggle]');
        var introOptions = Array.from(introMenu.querySelectorAll('[data-intro-option]'));
        var themeMenu = document.querySelector('[data-theme-menu]');
        var themeButton = document.querySelector('[data-theme-menu-toggle]');
        var seenKey = 'site-intro-seen-v1';
        var returnKey = 'site-intro-return-v1';

        function setOpen(isOpen, moveFocus) {
          introMenu.classList.toggle('open', isOpen);
          introButton.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
          if (isOpen && moveFocus && introOptions[0]) introOptions[0].focus();
        }

        function closeThemeMenu() {
          if (!themeMenu || !themeButton) return;
          themeMenu.classList.remove('open');
          themeButton.setAttribute('aria-expanded', 'false');
        }

        function openIntro(introPath) {
          if (!introPath) return;
          var currentPath = window.location.pathname + window.location.search + window.location.hash;
          var introUrl = new URL(introPath, window.location.origin);
          introUrl.searchParams.set('return', currentPath);

          try {
            localStorage.setItem(seenKey, '1');
            sessionStorage.setItem(returnKey, currentPath);
          } catch (error) {}

          window.location.href = introUrl.href;
        }

        introButton.addEventListener('click', function () {
          var nextOpen = !introMenu.classList.contains('open');
          closeThemeMenu();
          setOpen(nextOpen, false);
        });

        introButton.addEventListener('keydown', function (event) {
          if (event.key !== 'ArrowDown') return;
          event.preventDefault();
          closeThemeMenu();
          setOpen(true, true);
        });

        introOptions.forEach(function (option, index) {
          option.addEventListener('click', function () {
            openIntro(option.getAttribute('data-intro-url'));
          });

          option.addEventListener('keydown', function (event) {
            if (event.key !== 'ArrowDown' && event.key !== 'ArrowUp') return;
            event.preventDefault();
            var direction = event.key === 'ArrowDown' ? 1 : -1;
            var nextIndex = (index + direction + introOptions.length) % introOptions.length;
            introOptions[nextIndex].focus();
          });
        });

        if (themeButton) {
          themeButton.addEventListener('click', function () {
            setOpen(false, false);
          });
        }

        introMenu.addEventListener('focusout', function (event) {
          if (!introMenu.contains(event.relatedTarget)) setOpen(false, false);
        });

        document.addEventListener('keydown', function (event) {
          if (event.key !== 'Escape' || !introMenu.classList.contains('open')) return;
          setOpen(false, false);
          introButton.focus();
        });

        document.addEventListener('click', function (event) {
          if (!introMenu.contains(event.target)) setOpen(false, false);
        });
      })();
    </script>
    <script is:inline>
      (function () {
        var search = document.querySelector('[data-site-search]');
        if (!search) return;

        var toggle = search.querySelector('[data-search-toggle]');
        var panel = search.querySelector('.nav-search-panel');
        var input = search.querySelector('[data-search-input]');
        var results = search.querySelector('[data-search-results]');
        var articlesUrl = search.getAttribute('data-articles-url') || '#';
        var closeTimer;
        var items = [];

        try {
          items = JSON.parse(search.getAttribute('data-search-items') || '[]');
        } catch (error) {}

        function itemText(item) {
          return [item.title, item.description].concat(item.keywords || []).join(' ').toLowerCase();
        }

        function escapeHtml(value) {
          return String(value)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
        }

        function setOpen(isOpen) {
          if (isOpen && closeTimer) {
            window.clearTimeout(closeTimer);
            closeTimer = undefined;
          }
          search.classList.toggle('open', isOpen);
          toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        }

        function scheduleClose() {
          if (closeTimer) window.clearTimeout(closeTimer);
          closeTimer = window.setTimeout(function () {
            if (!search.matches(':hover') && !search.matches(':focus-within')) {
              setOpen(false);
            }
            closeTimer = undefined;
          }, 200);
        }

        function resultHtml(item) {
          return [
              '<a class="nav-search-result" href="' + escapeHtml(item.href) + '">',
              '<span>' + escapeHtml(item.type) + '</span>',
              '<b>' + escapeHtml(item.title) + '</b>',
              '<small>' + escapeHtml(item.description) + '</small>',
              '</a>',
            ].join('');
        }

        function render(query) {
          var normalizedQuery = query.trim().toLowerCase();

          if (!normalizedQuery) {
            var filters = ['生活', '实践', '教程', '视觉实验室'];
            var recentItems = items.filter(function (item) {
              return item.type === '文章';
            }).slice(0, 6);

            results.innerHTML = [
              '<section class="nav-search-section">',
              '<div class="nav-search-section-head"><strong>快速筛选</strong></div>',
              '<div class="nav-search-filters">',
              filters.map(function (filter) {
                return '<button type="button" data-search-filter="' + escapeHtml(filter) + '">' + escapeHtml(filter) + '</button>';
              }).join(''),
              '</div>',
              '</section>',
              '<section class="nav-search-section">',
              '<div class="nav-search-section-head"><strong>最近更新</strong><span>' + recentItems.length + ' 篇</span></div>',
              recentItems.map(resultHtml).join(''),
              '</section>',
              '<a class="nav-search-all-link" href="' + escapeHtml(articlesUrl) + '">查看全部文章 <span aria-hidden="true">→</span></a>',
            ].join('');
            results.scrollTop = 0;
            return;
          }

          var matches = items.filter(function (item) {
            return itemText(item).includes(normalizedQuery);
          });

          results.innerHTML = [
            '<div class="nav-search-section-head nav-search-match-head"><strong>搜索结果</strong><span>' + matches.length + ' 条</span></div>',
            matches.length
              ? matches.map(resultHtml).join('')
              : '<p class="nav-search-empty">没有找到匹配内容</p>',
          ].join('');
          results.scrollTop = 0;
        }

        render('');

        toggle.addEventListener('click', function () {
          setOpen(true);
          input.focus();
        });

        search.addEventListener('mouseenter', function () {
          setOpen(true);
        });

        search.addEventListener('mouseleave', scheduleClose);

        search.addEventListener('focusin', function () {
          setOpen(true);
        });

        search.addEventListener('focusout', function (event) {
          if (!search.contains(event.relatedTarget)) scheduleClose();
        });

        input.addEventListener('input', function () {
          render(input.value);
        });

        results.addEventListener('click', function (event) {
          var filter = event.target.closest('[data-search-filter]');
          if (!filter) return;
          input.value = filter.getAttribute('data-search-filter') || '';
          render(input.value);
          input.focus();
        });

        panel.addEventListener('wheel', function (event) {
          if (event.ctrlKey) return;
          event.preventDefault();
          var distance = event.deltaY;
          if (event.deltaMode === 1) distance *= 18;
          if (event.deltaMode === 2) distance *= results.clientHeight;
          results.scrollTop += distance;
        }, { passive: false });

        document.addEventListener('keydown', function (event) {
          if (event.key === 'Escape') {
            setOpen(false);
            input.blur();
          }
        });

        document.addEventListener('click', function (event) {
          if (!search.contains(event.target)) {
            if (closeTimer) window.clearTimeout(closeTimer);
            setOpen(false);
          }
        });
      })();
    </script>
    <style is:inline>
      .has-copy-code {
        padding-top: 42px;
        position: relative;
      }

      .hero-code.has-copy-code {
        padding-top: 0;
      }

      .terminal-panel {
        position: relative;
      }

      .terminal-panel > .copy-code-button {
        background: transparent;
        border-color: transparent;
        border-radius: 6px;
        color: #64748b;
        height: 28px;
        right: 10px;
        top: 7px;
        width: 28px;
        z-index: 2;
      }

      .copy-code-button {
        align-items: center;
        background: rgba(15, 23, 42, 0.72);
        border: 1px solid rgba(148, 163, 184, 0.42);
        border-radius: 999px;
        color: #cbd5e1;
        cursor: pointer;
        display: inline-flex;
        height: 30px;
        justify-content: center;
        padding: 0;
        position: absolute;
        right: 12px;
        top: 10px;
        width: 30px;
      }

      .copy-code-button svg {
        height: 15px;
        width: 15px;
      }

      .copy-code-button:hover {
        background: rgba(30, 41, 59, 0.88);
        color: #ffffff;
      }

      .terminal-panel > .copy-code-button:hover {
        background: rgba(148, 163, 184, 0.1);
        border-color: rgba(148, 163, 184, 0.16);
        color: #cbd5e1;
      }

      .copy-code-button.is-copied {
        color: #ffffff;
      }

      .terminal-panel > .copy-code-button.is-copied {
        background: rgba(34, 197, 94, 0.12);
        color: #86efac;
      }
    </style>
    <script is:inline>
      (function () {
        document.querySelectorAll('pre > code').forEach(function (code) {
          var pre = code.parentElement;
          if (!pre || pre.closest('.mermaid-card')) return;
          var copyHost = pre.closest('.terminal-panel') || pre;
          if (copyHost.querySelector('[data-copy-code]')) return;
          pre.classList.add('has-copy-code');

          var button = document.createElement('button');
          button.type = 'button';
          button.className = 'copy-code-button';
          button.dataset.copyCode = '';
          var copyIcon = '<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>';
          var copiedIcon = '<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>';
          button.innerHTML = copyIcon;
          button.setAttribute('aria-label', '复制代码');
          button.setAttribute('title', '复制代码');

          button.addEventListener('click', function () {
            navigator.clipboard.writeText(code.innerText).then(function () {
              button.innerHTML = copiedIcon;
              button.classList.add('is-copied');
              button.setAttribute('aria-label', '已复制');
              button.setAttribute('title', '已复制');
              window.setTimeout(function () {
                button.innerHTML = copyIcon;
                button.classList.remove('is-copied');
                button.setAttribute('aria-label', '复制代码');
                button.setAttribute('title', '复制代码');
              }, 1400);
            });
          });

          copyHost.appendChild(button);
        });
      })();
    </script>
  </body>
</html>
