---
import { siteMeta } from '../data/site';
import { withBase } from '../utils/paths';
---

<!doctype html>
<html lang="zh-CN" class="cosmic-opening-page">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="天体序章，以星轨、日蚀与光门构成的沉浸式开场。"
    />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#02050d" />
    <link rel="icon" type="image/png" sizes="256x256" href={withBase('/favicon.png?v=4')} />
    <title>天体序章 | {siteMeta.siteName}</title>
  </head>

  <body data-pagefind-ignore>
    <main
      class="cosmic-opening"
      data-cosmic-opening
      data-home-url={withBase('/')}
      aria-label="天体序章开屏动画"
    >
      <canvas class="cosmic-canvas" data-cosmic-canvas aria-hidden="true"></canvas>
      <div class="cosmic-veil" aria-hidden="true"></div>
      <div class="cosmic-glass" aria-hidden="true"></div>

      <header class="sequence-head">
        <div class="sequence-mark" aria-hidden="true">
          <span class="mark-dot"></span>
          <span>天体序章</span>
          <span class="mark-index">03</span>
        </div>

        <button class="skip-button" type="button" data-skip>
          <span>跳过动画</span>
          <span class="skip-arrow" aria-hidden="true"></span>
        </button>
      </header>

      <section class="prologue prologue-one" data-prologue="one">
        <p class="prologue-index">坐标 00 / 04</p>
        <p class="prologue-line">每一次记录，</p>
        <p class="prologue-line prologue-line-muted">都从一束微光开始。</p>
      </section>

      <section class="prologue prologue-two" data-prologue="two">
        <p class="prologue-index">坐标 01 / 04</p>
        <p class="prologue-line">穿过噪声与引力，</p>
        <p class="prologue-line prologue-line-muted">寻找值得留下的轨迹。</p>
      </section>

      <section class="prologue prologue-three" data-prologue="three">
        <p class="prologue-index">坐标 02 / 04</p>
        <p class="prologue-line">让复杂的事，</p>
        <p class="prologue-line prologue-line-muted">慢慢显出它原本的形状。</p>
      </section>

      <section class="prologue prologue-four" data-prologue="four">
        <p class="prologue-index">坐标 03 / 04</p>
        <p class="prologue-line">抵达之前，</p>
        <p class="prologue-line prologue-line-muted">先看一眼自己的宇宙。</p>
      </section>

      <section class="finale" data-finale aria-labelledby="cosmic-title">
        <p class="finale-kicker">个人知识宇宙 · 已抵达</p>
        <h1 id="cosmic-title">
          <span>{siteMeta.authorName}的</span>
          <strong>技术笔记</strong>
        </h1>
        <p class="finale-note">{siteMeta.siteDescription}</p>
        <div class="finale-actions">
          <a class="enter-button" href={withBase('/')} data-enter>
            <span>进入博客</span>
            <span class="enter-orbit" aria-hidden="true"></span>
          </a>
          <button class="replay-button" type="button" data-replay hidden>重新播放</button>
        </div>
      </section>

      <div class="sequence-foot" aria-hidden="true">
        <span class="chapter-name" data-chapter>正在唤醒</span>
        <div class="progress-track">
          <span class="progress-fill" data-progress></span>
        </div>
        <span class="time-left" data-time>20 秒</span>
      </div>

      <p class="interaction-hint" data-interaction-hint aria-hidden="true">双击画面直接进入</p>

      <p class="sr-only" aria-live="polite" data-status>天体序章即将开始</p>

      <noscript>
        <style>
          .cosmic-canvas {
            background:
              radial-gradient(circle at 64% 43%, rgba(79, 131, 183, 0.24), transparent 26%),
              radial-gradient(circle at 36% 66%, rgba(91, 71, 152, 0.2), transparent 32%),
              #02050d;
          }

          .prologue,
          .sequence-foot,
          .skip-button {
            display: none !important;
          }

          .finale {
            opacity: 1 !important;
            pointer-events: auto !important;
            transform: none !important;
            visibility: visible !important;
          }
        </style>
      </noscript>
    </main>

    <style is:inline>
      :root {
        color-scheme: dark;
        font-family:
          Inter, ui-sans-serif, -apple-system, BlinkMacSystemFont, "Segoe UI",
          "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
        font-synthesis: none;
        text-rendering: optimizeLegibility;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        height: 100%;
        margin: 0;
        overflow: hidden;
      }

      body {
        background: #02050d;
        color: #f4f7ff;
      }

      button,
      a {
        color: inherit;
        font: inherit;
      }

      button {
        -webkit-tap-highlight-color: transparent;
      }

      [hidden] {
        display: none !important;
      }

      .cosmic-opening {
        background: #02050d;
        height: 100svh;
        isolation: isolate;
        min-height: 560px;
        overflow: hidden;
        position: relative;
        user-select: none;
        width: 100%;
      }

      .cosmic-canvas {
        height: 100%;
        inset: 0;
        position: absolute;
        width: 100%;
        z-index: 0;
      }

      .cosmic-veil {
        background:
          radial-gradient(circle at 50% 48%, transparent 20%, rgba(1, 4, 12, 0.14) 56%, rgba(1, 3, 9, 0.72) 112%),
          linear-gradient(180deg, rgba(1, 4, 12, 0.28), transparent 26%, transparent 68%, rgba(1, 4, 12, 0.5));
        inset: 0;
        pointer-events: none;
        position: absolute;
        z-index: 2;
      }

      .cosmic-glass {
        background: linear-gradient(
          112deg,
          transparent 0%,
          rgba(139, 200, 225, 0.025) 42%,
          rgba(255, 255, 255, 0.07) 49.8%,
          transparent 50.2%,
          transparent 100%
        );
        inset: 0;
        opacity: 0.65;
        pointer-events: none;
        transform: translateX(-62%);
        transition: transform 1.8s cubic-bezier(0.2, 0.7, 0.1, 1);
        z-index: 3;
      }

      .cosmic-opening.is-finished .cosmic-glass {
        transform: translateX(55%);
      }

      .sequence-head {
        align-items: center;
        display: flex;
        justify-content: space-between;
        left: max(24px, env(safe-area-inset-left));
        position: absolute;
        right: max(24px, env(safe-area-inset-right));
        top: max(22px, env(safe-area-inset-top));
        z-index: 20;
      }

      .sequence-mark {
        align-items: center;
        color: rgba(218, 230, 244, 0.54);
        display: flex;
        font-size: 11px;
        font-weight: 500;
        gap: 10px;
        letter-spacing: 0.2em;
      }

      .mark-dot {
        background: #9ce7e0;
        border-radius: 50%;
        box-shadow: 0 0 14px rgba(116, 225, 218, 0.84);
        height: 5px;
        width: 5px;
      }

      .mark-index {
        border-left: 1px solid rgba(206, 222, 239, 0.18);
        color: rgba(218, 230, 244, 0.32);
        padding-left: 10px;
      }

      .skip-button,
      .replay-button {
        align-items: center;
        background: transparent;
        border: 0;
        cursor: pointer;
        display: inline-flex;
      }

      .skip-button {
        color: rgba(220, 231, 242, 0.54);
        font-size: 12px;
        gap: 12px;
        letter-spacing: 0.12em;
        padding: 10px 0;
        transition: color 220ms ease;
      }

      .skip-button:hover,
      .skip-button:focus-visible {
        color: #ffffff;
      }

      .skip-button:focus-visible,
      .replay-button:focus-visible,
      .enter-button:focus-visible {
        outline: 1px solid rgba(144, 225, 226, 0.8);
        outline-offset: 6px;
      }

      .skip-arrow {
        border-right: 1px solid currentColor;
        border-top: 1px solid currentColor;
        height: 7px;
        position: relative;
        transform: rotate(45deg);
        width: 7px;
      }

      .skip-arrow::before {
        background: currentColor;
        content: "";
        height: 1px;
        position: absolute;
        right: -2px;
        top: 2px;
        transform: rotate(-45deg);
        transform-origin: right center;
        width: 19px;
      }

      .prologue {
        left: clamp(28px, 8vw, 132px);
        max-width: min(660px, calc(100vw - 56px));
        opacity: 0;
        pointer-events: none;
        position: absolute;
        top: 50%;
        transform: translate3d(0, 28px, 0);
        visibility: hidden;
        z-index: 10;
      }

      .prologue-two {
        left: auto;
        right: clamp(28px, 8vw, 132px);
        text-align: right;
      }

      .prologue-three {
        top: 56%;
      }

      .prologue-four {
        left: auto;
        right: clamp(28px, 9vw, 156px);
        text-align: right;
        top: 44%;
      }

      .prologue-index {
        color: rgba(143, 207, 213, 0.52);
        font-size: 10px;
        font-weight: 500;
        letter-spacing: 0.28em;
        margin: 0 0 16px;
      }

      .prologue-line {
        color: rgba(244, 248, 255, 0.94);
        font-size: clamp(25px, 3vw, 48px);
        font-weight: 420;
        letter-spacing: -0.035em;
        line-height: 1.34;
        margin: 0;
        text-wrap: balance;
      }

      .prologue-line-muted {
        color: rgba(207, 221, 237, 0.48);
        font-size: clamp(18px, 2vw, 31px);
        letter-spacing: -0.02em;
        margin-top: 4px;
      }

      .finale {
        left: clamp(28px, 8vw, 132px);
        max-width: min(760px, calc(100vw - 56px));
        opacity: 0;
        pointer-events: none;
        position: absolute;
        top: 50%;
        transform: translate3d(0, 34px, 0);
        visibility: hidden;
        z-index: 12;
      }

      .finale-kicker {
        color: rgba(137, 218, 214, 0.72);
        font-size: 11px;
        font-weight: 550;
        letter-spacing: 0.28em;
        margin: 0 0 18px;
      }

      .finale h1 {
        font-size: clamp(48px, 8.7vw, 132px);
        font-weight: 400;
        letter-spacing: -0.065em;
        line-height: 0.92;
        margin: 0;
      }

      .finale h1 span,
      .finale h1 strong {
        display: block;
      }

      .finale h1 span {
        color: rgba(235, 240, 249, 0.58);
        font-size: 0.48em;
        font-weight: 430;
        letter-spacing: -0.035em;
        margin-bottom: 0.12em;
      }

      .finale h1 strong {
        background: linear-gradient(102deg, #f9fbff 4%, #c8e3ec 48%, #d5c4ef 96%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        font-weight: 480;
        padding-bottom: 0.08em;
      }

      .finale-note {
        color: rgba(209, 222, 237, 0.58);
        font-size: clamp(14px, 1.3vw, 18px);
        line-height: 1.8;
        margin: clamp(18px, 3vh, 32px) 0 0;
        max-width: 610px;
      }

      .finale-actions {
        align-items: center;
        display: flex;
        gap: 24px;
        margin-top: clamp(24px, 4vh, 42px);
      }

      .enter-button {
        --magnet-x: 0px;
        --magnet-y: 0px;
        align-items: center;
        background: rgba(225, 242, 247, 0.94);
        border: 1px solid rgba(255, 255, 255, 0.7);
        border-radius: 999px;
        box-shadow:
          0 16px 54px rgba(60, 147, 163, 0.18),
          inset 0 1px 0 rgba(255, 255, 255, 0.95);
        color: #081117;
        display: inline-flex;
        font-size: 13px;
        font-weight: 650;
        gap: 18px;
        letter-spacing: 0.08em;
        min-height: 50px;
        padding: 0 20px 0 24px;
        text-decoration: none;
        transition:
          box-shadow 260ms ease,
          transform 260ms ease;
        transform: translate3d(var(--magnet-x), var(--magnet-y), 0);
      }

      .enter-button:hover {
        box-shadow:
          0 20px 64px rgba(82, 182, 190, 0.3),
          inset 0 1px 0 rgba(255, 255, 255, 0.95);
        transform: translate3d(var(--magnet-x), calc(var(--magnet-y) - 2px), 0);
      }

      .enter-orbit {
        border: 1px solid rgba(9, 28, 36, 0.36);
        border-radius: 50%;
        height: 22px;
        position: relative;
        transition: transform 720ms cubic-bezier(0.2, 0.75, 0.2, 1);
        width: 22px;
      }

      .enter-button:hover .enter-orbit {
        transform: rotate(112deg);
      }

      .enter-orbit::after {
        background: #0e5f68;
        border-radius: 50%;
        content: "";
        height: 4px;
        position: absolute;
        right: -1px;
        top: 2px;
        width: 4px;
      }

      .replay-button {
        color: rgba(219, 231, 243, 0.55);
        font-size: 12px;
        letter-spacing: 0.11em;
        padding: 12px 0;
        transition: color 220ms ease;
      }

      .replay-button:hover {
        color: #ffffff;
      }

      .sequence-foot {
        align-items: center;
        bottom: max(24px, env(safe-area-inset-bottom));
        color: rgba(205, 219, 235, 0.36);
        display: grid;
        font-size: 10px;
        gap: 18px;
        grid-template-columns: auto minmax(100px, 240px) 42px;
        left: max(24px, env(safe-area-inset-left));
        letter-spacing: 0.16em;
        position: absolute;
        text-transform: uppercase;
        z-index: 20;
      }

      .chapter-name {
        min-width: 68px;
      }

      .progress-track {
        background: rgba(198, 218, 237, 0.13);
        height: 1px;
        overflow: hidden;
        position: relative;
        width: 100%;
      }

      .progress-fill {
        background: linear-gradient(90deg, #8dded8, #bcc9f2);
        box-shadow: 0 0 10px rgba(135, 220, 215, 0.72);
        display: block;
        height: 100%;
        transform: scaleX(0);
        transform-origin: left center;
        width: 100%;
      }

      .time-left {
        font-variant-numeric: tabular-nums;
        text-align: right;
      }

      .interaction-hint {
        bottom: max(24px, env(safe-area-inset-bottom));
        color: rgba(205, 219, 235, 0.3);
        font-size: 9px;
        letter-spacing: 0.2em;
        margin: 0;
        opacity: 0;
        pointer-events: none;
        position: absolute;
        right: max(24px, env(safe-area-inset-right));
        text-transform: uppercase;
        z-index: 20;
      }

      .interaction-hint.is-visible {
        animation: hint-reveal 3.2s ease 0.35s both;
      }

      .sr-only {
        clip: rect(0, 0, 0, 0);
        clip-path: inset(50%);
        height: 1px;
        overflow: hidden;
        position: absolute;
        white-space: nowrap;
        width: 1px;
      }

      @media (max-width: 720px) {
        .cosmic-opening {
          min-height: 500px;
        }

        .sequence-head {
          left: max(20px, env(safe-area-inset-left));
          right: max(20px, env(safe-area-inset-right));
          top: max(18px, env(safe-area-inset-top));
        }

        .sequence-mark {
          font-size: 9px;
          gap: 8px;
          letter-spacing: 0.16em;
        }

        .skip-button {
          font-size: 11px;
        }

        .prologue,
        .prologue-two,
        .prologue-three,
        .prologue-four {
          left: 24px;
          max-width: calc(100vw - 48px);
          right: auto;
          text-align: left;
          top: 58%;
        }

        .prologue-two,
        .prologue-four {
          text-align: right;
        }

        .prologue-index {
          font-size: 9px;
          margin-bottom: 12px;
        }

        .prologue-line {
          font-size: clamp(24px, 7.6vw, 34px);
        }

        .prologue-line-muted {
          font-size: clamp(17px, 5vw, 23px);
          line-height: 1.5;
        }

        .finale {
          left: 24px;
          max-width: calc(100vw - 48px);
          top: 49%;
        }

        .finale-kicker {
          font-size: 9px;
          letter-spacing: 0.22em;
          margin-bottom: 14px;
        }

        .finale h1 {
          font-size: clamp(47px, 15vw, 76px);
          letter-spacing: -0.055em;
          line-height: 0.96;
        }

        .finale-note {
          font-size: 13px;
          line-height: 1.7;
          max-width: 330px;
        }

        .finale-actions {
          gap: 20px;
          margin-top: 26px;
        }

        .enter-button {
          min-height: 46px;
          padding: 0 16px 0 20px;
        }

        .sequence-foot {
          bottom: max(20px, env(safe-area-inset-bottom));
          gap: 12px;
          grid-template-columns: auto minmax(72px, 1fr) 38px;
          left: max(20px, env(safe-area-inset-left));
          right: max(20px, env(safe-area-inset-right));
        }

        .interaction-hint {
          display: none;
        }
      }

      @media (max-height: 640px) {
        .prologue,
        .prologue-two,
        .prologue-three,
        .prologue-four {
          top: 48%;
        }

        .finale {
          top: 44%;
        }

        .finale-note {
          margin-top: 14px;
        }

        .finale-actions {
          margin-top: 18px;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .cosmic-glass,
        .enter-button {
          transition: none;
        }

        .interaction-hint {
          display: none;
        }
      }

      @keyframes hint-reveal {
        0%,
        100% {
          opacity: 0;
          transform: translateY(4px);
        }

        18%,
        72% {
          opacity: 1;
          transform: translateY(0);
        }
      }
    </style>

    <script is:inline>
      (function () {
        var root = document.querySelector('[data-cosmic-opening]');
        if (!root) return;

        var canvas = root.querySelector('[data-cosmic-canvas]');
        var context = canvas.getContext('2d', { alpha: false });
        var skipButton = root.querySelector('[data-skip]');
        var replayButton = root.querySelector('[data-replay]');
        var enterButton = root.querySelector('[data-enter]');
        var finale = root.querySelector('[data-finale]');
        var progressFill = root.querySelector('[data-progress]');
        var timeLeft = root.querySelector('[data-time]');
        var chapterName = root.querySelector('[data-chapter]');
        var status = root.querySelector('[data-status]');
        var interactionHint = root.querySelector('[data-interaction-hint]');
        var params = new URLSearchParams(window.location.search);
        var returnKey = 'site-intro-return-v1';
        var prologues = {
          one: root.querySelector('[data-prologue="one"]'),
          two: root.querySelector('[data-prologue="two"]'),
          three: root.querySelector('[data-prologue="three"]'),
          four: root.querySelector('[data-prologue="four"]'),
        };

        var duration = 20000;
        var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
        var width = 0;
        var height = 0;
        var pixelRatio = 1;
        var animationFrame = 0;
        var startedAt = 0;
        var currentProgress = 0;
        var isPlaying = false;
        var lastChapter = '';
        var pointerX = 0;
        var pointerY = 0;
        var targetPointerX = 0;
        var targetPointerY = 0;
        var pointerCanvasX = 0;
        var pointerCanvasY = 0;
        var pointerInfluence = 0;
        var targetPointerInfluence = 0;
        var stars = [];
        var dust = [];
        var ripples = [];
        var randomSeed = 20260717;

        function resolveReturnUrl(value) {
          try {
            var target = new URL(value || root.dataset.homeUrl, window.location.origin);
            if (target.origin !== window.location.origin) return root.dataset.homeUrl;
            return target.pathname + target.search + target.hash;
          } catch (error) {
            return root.dataset.homeUrl;
          }
        }

        var returnUrl = resolveReturnUrl(params.get('return'));
        enterButton.href = returnUrl;
        enterButton.addEventListener('click', function () {
          try {
            sessionStorage.setItem(returnKey, returnUrl);
          } catch (error) {}
        });

        function random() {
          randomSeed = (randomSeed * 1664525 + 1013904223) >>> 0;
          return randomSeed / 4294967296;
        }

        function clamp(value, minimum, maximum) {
          return Math.min(maximum, Math.max(minimum, value));
        }

        function phase(progress, start, end) {
          return clamp((progress - start) / (end - start), 0, 1);
        }

        function ease(value) {
          return value * value * (3 - 2 * value);
        }

        function band(progress, enterStart, enterEnd, exitStart, exitEnd) {
          return ease(phase(progress, enterStart, enterEnd))
            * (1 - ease(phase(progress, exitStart, exitEnd)));
        }

        function setLayer(element, opacity, y, scale) {
          element.style.opacity = opacity.toFixed(3);
          element.style.transform =
            'translate3d(0,' + y.toFixed(2) + 'px,0) scale(' + scale.toFixed(4) + ')';
          element.style.visibility = opacity > 0.002 ? 'visible' : 'hidden';
        }

        function createField() {
          randomSeed = 20260717;
          stars = [];
          dust = [];

          var starCount = width < 700 ? 105 : 185;
          for (var index = 0; index < starCount; index += 1) {
            stars.push({
              x: random() * 2 - 1,
              y: random() * 2 - 1,
              z: random(),
              size: 0.35 + random() * 1.25,
              glow: random(),
              speed: 0.62 + random() * 0.86,
              tone: random(),
            });
          }

          var dustCount = width < 700 ? 22 : 38;
          for (var dustIndex = 0; dustIndex < dustCount; dustIndex += 1) {
            dust.push({
              angle: random() * Math.PI * 2,
              radius: 0.56 + random() * 1.18,
              drift: 0.4 + random() * 0.75,
              size: 0.7 + random() * 2.1,
              alpha: 0.1 + random() * 0.38,
            });
          }
        }

        function resizeCanvas() {
          width = Math.max(1, window.innerWidth);
          height = Math.max(1, window.innerHeight);
          pixelRatio = Math.min(window.devicePixelRatio || 1, 1.6);
          canvas.width = Math.round(width * pixelRatio);
          canvas.height = Math.round(height * pixelRatio);
          canvas.style.width = width + 'px';
          canvas.style.height = height + 'px';
          context.setTransform(pixelRatio, 0, 0, pixelRatio, 0, 0);
          if (!pointerCanvasX && !pointerCanvasY) {
            pointerCanvasX = width * 0.5;
            pointerCanvasY = height * 0.5;
          }
          createField();
          drawSpace(currentProgress, performance.now());
        }

        function drawStarField(progress, time, centerX, centerY) {
          var awake = ease(phase(progress, 0.01, 0.14));
          var rush = ease(phase(progress, 0.5, 0.72))
            * (1 - ease(phase(progress, 0.73, 0.82)));
          var travel = progress * 0.62 + rush * 0.18;

          for (var index = 0; index < stars.length; index += 1) {
            var star = stars[index];
            var depth = (star.z - travel * star.speed) % 1;
            if (depth < 0) depth += 1;

            var nearness = 1 - depth;
            var spread = 0.18 + nearness * nearness * (0.92 + rush * 1.25);
            var starX = centerX + star.x * width * spread;
            var starY = centerY + star.y * height * spread;

            if (starX < -12 || starX > width + 12 || starY < -12 || starY > height + 12) {
              continue;
            }

            var flicker = 0.72 + Math.sin(time * 0.0017 + index * 2.31) * 0.28;
            var pointerSpark = pointerInfluence * clamp(
              1 - Math.hypot(starX - pointerCanvasX, starY - pointerCanvasY)
                / Math.max(130, Math.min(width, height) * 0.22),
              0,
              1
            );
            var alpha = awake * (0.12 + nearness * 0.74) * flicker * (1 + pointerSpark * 0.48);
            var starSize = star.size * (0.45 + nearness * 1.8) * (1 + pointerSpark * 0.28);
            var red = star.tone > 0.72 ? 198 : 174;
            var green = star.tone > 0.72 ? 191 : 220;
            var blue = star.tone > 0.72 ? 236 : 239;

            context.fillStyle = 'rgba(' + red + ',' + green + ',' + blue + ',' + alpha.toFixed(3) + ')';
            context.beginPath();
            context.arc(starX, starY, starSize, 0, Math.PI * 2);
            context.fill();

            if (rush > 0.08 && nearness > 0.45) {
              context.strokeStyle = 'rgba(154,215,230,' + (alpha * rush * 0.44).toFixed(3) + ')';
              context.lineWidth = Math.max(0.4, starSize * 0.45);
              context.beginPath();
              context.moveTo(starX, starY);
              context.lineTo(
                starX + (starX - centerX) * rush * 0.075,
                starY + (starY - centerY) * rush * 0.075
              );
              context.stroke();
            }
          }
        }

        function drawOrbitDust(progress, time, centerX, centerY, radius) {
          var orbitAmount = band(progress, 0.1, 0.22, 0.69, 0.79);
          if (orbitAmount <= 0.001) return;

          context.save();
          context.translate(centerX, centerY);
          context.rotate(-0.24);
          context.scale(1, 0.34);

          for (var index = 0; index < dust.length; index += 1) {
            var item = dust[index];
            var angle = item.angle + time * 0.00008 * item.drift;
            var orbitRadius = radius * item.radius;
            var x = Math.cos(angle) * orbitRadius;
            var y = Math.sin(angle) * orbitRadius;
            var alpha = orbitAmount * item.alpha * (0.45 + Math.sin(angle + time * 0.0004) * 0.25);
            context.fillStyle = 'rgba(167,220,226,' + Math.max(0, alpha).toFixed(3) + ')';
            context.beginPath();
            context.arc(x, y, item.size, 0, Math.PI * 2);
            context.fill();
          }

          context.restore();
        }

        function drawOrbitLines(progress, time, centerX, centerY, radius) {
          var orbitAmount = band(progress, 0.08, 0.19, 0.63, 0.77);
          var collapseAmount = ease(phase(progress, 0.63, 0.79));
          if (orbitAmount <= 0.001) return;

          context.save();
          context.translate(centerX, centerY);
          context.rotate(-0.22 + time * 0.000008);
          context.scale(1, 0.36 + collapseAmount * 0.14);

          for (var ring = 0; ring < 4; ring += 1) {
            var ringRadius = radius * (1.42 + ring * 0.33);
            var lineAlpha = orbitAmount * (0.2 - ring * 0.025);
            context.strokeStyle = 'rgba(140,208,221,' + lineAlpha.toFixed(3) + ')';
            context.lineWidth = ring === 0 ? 1.15 : 0.7;
            context.setLineDash(ring % 2 === 0 ? [] : [2, 8 + ring * 2]);
            context.lineDashOffset = -time * 0.012 * (ring % 2 === 0 ? 1 : -1);
            context.beginPath();
            context.arc(0, 0, ringRadius, 0, Math.PI * 2);
            context.stroke();
          }

          context.setLineDash([]);
          context.restore();
        }

        function drawCelestialBody(progress, time, centerX, centerY) {
          var arrive = ease(phase(progress, 0.08, 0.24));
          var eclipse = ease(phase(progress, 0.28, 0.48));
          var dissolve = ease(phase(progress, 0.69, 0.84));
          var radius = Math.min(width, height) * (0.085 + arrive * 0.115);
          var bodyAlpha = arrive * (1 - dissolve);

          if (bodyAlpha <= 0.001) return;

          var haloRadius = radius * (2.05 + eclipse * 0.55);
          var halo = context.createRadialGradient(
            centerX,
            centerY,
            radius * 0.72,
            centerX,
            centerY,
            haloRadius
          );
          halo.addColorStop(0, 'rgba(161,228,232,' + (0.34 * bodyAlpha).toFixed(3) + ')');
          halo.addColorStop(0.08, 'rgba(117,190,214,' + (0.19 * bodyAlpha).toFixed(3) + ')');
          halo.addColorStop(0.35, 'rgba(89,104,182,' + (0.09 * bodyAlpha).toFixed(3) + ')');
          halo.addColorStop(1, 'rgba(5,8,18,0)');
          context.fillStyle = halo;
          context.beginPath();
          context.arc(centerX, centerY, haloRadius, 0, Math.PI * 2);
          context.fill();

          context.save();
          context.globalAlpha = bodyAlpha;
          context.beginPath();
          context.arc(centerX, centerY, radius, 0, Math.PI * 2);
          context.clip();

          var surface = context.createRadialGradient(
            centerX + radius * 0.46,
            centerY - radius * 0.34,
            radius * 0.04,
            centerX,
            centerY,
            radius * 1.2
          );
          surface.addColorStop(0, '#d3f2ee');
          surface.addColorStop(0.12, '#79b8c1');
          surface.addColorStop(0.48, '#233a55');
          surface.addColorStop(0.78, '#09111f');
          surface.addColorStop(1, '#02050d');
          context.fillStyle = surface;
          context.fillRect(centerX - radius, centerY - radius, radius * 2, radius * 2);

          context.fillStyle = 'rgba(1,3,9,' + (0.28 + eclipse * 0.72).toFixed(3) + ')';
          context.beginPath();
          context.arc(
            centerX - radius * (0.32 - eclipse * 0.16),
            centerY + radius * 0.03,
            radius * 1.02,
            0,
            Math.PI * 2
          );
          context.fill();

          context.strokeStyle = 'rgba(207,239,240,' + (0.22 * (1 - eclipse)).toFixed(3) + ')';
          context.lineWidth = 0.8;
          for (var contour = 0; contour < 5; contour += 1) {
            context.beginPath();
            context.arc(
              centerX + radius * 0.16,
              centerY - radius * 0.08,
              radius * (0.22 + contour * 0.13),
              -1.15,
              1.15
            );
            context.stroke();
          }

          context.restore();

          context.strokeStyle = 'rgba(190,236,236,' + (0.62 * bodyAlpha).toFixed(3) + ')';
          context.lineWidth = 1.2;
          context.beginPath();
          context.arc(centerX, centerY, radius + 1.5, -1.22, 1.18);
          context.stroke();

          var flareAmount = band(progress, 0.31, 0.43, 0.57, 0.69);
          if (flareAmount > 0.001) {
            var flare = context.createLinearGradient(
              centerX - width * 0.38,
              centerY,
              centerX + width * 0.38,
              centerY
            );
            flare.addColorStop(0, 'rgba(126,211,221,0)');
            flare.addColorStop(0.47, 'rgba(159,231,232,' + (0.2 * flareAmount).toFixed(3) + ')');
            flare.addColorStop(0.5, 'rgba(246,255,255,' + (0.68 * flareAmount).toFixed(3) + ')');
            flare.addColorStop(0.53, 'rgba(159,231,232,' + (0.2 * flareAmount).toFixed(3) + ')');
            flare.addColorStop(1, 'rgba(126,211,221,0)');
            context.fillStyle = flare;
            context.fillRect(centerX - width * 0.38, centerY - 0.5, width * 0.76, 1);
          }

          var moonAmount = band(progress, 0.22, 0.33, 0.58, 0.7);
          if (moonAmount > 0.001) {
            var moonAngle = -1.9 + phase(progress, 0.22, 0.7) * Math.PI * 2.1;
            var moonOrbit = radius * 1.82;
            var moonX = centerX + Math.cos(moonAngle) * moonOrbit;
            var moonY = centerY + Math.sin(moonAngle) * moonOrbit * 0.38;
            context.fillStyle = 'rgba(220,197,171,' + (0.78 * moonAmount).toFixed(3) + ')';
            context.beginPath();
            context.arc(moonX, moonY, Math.max(2.4, radius * 0.035), 0, Math.PI * 2);
            context.fill();
          }
        }

        function drawPortal(progress, centerX, centerY) {
          var portalAmount = ease(phase(progress, 0.63, 0.82))
            * (1 - ease(phase(progress, 0.82, 0.92)));
          if (portalAmount <= 0.001) return;

          var radius = Math.min(width, height) * (0.12 + portalAmount * 0.33);
          var portal = context.createRadialGradient(
            centerX,
            centerY,
            radius * 0.58,
            centerX,
            centerY,
            radius
          );
          portal.addColorStop(0, 'rgba(7,12,25,0)');
          portal.addColorStop(0.72, 'rgba(104,188,207,' + (0.08 * portalAmount).toFixed(3) + ')');
          portal.addColorStop(0.91, 'rgba(190,239,239,' + (0.34 * portalAmount).toFixed(3) + ')');
          portal.addColorStop(1, 'rgba(224,246,246,0)');
          context.fillStyle = portal;
          context.beginPath();
          context.arc(centerX, centerY, radius, 0, Math.PI * 2);
          context.fill();

          context.strokeStyle = 'rgba(201,238,239,' + (0.42 * portalAmount).toFixed(3) + ')';
          context.lineWidth = 0.8;
          context.beginPath();
          context.arc(centerX, centerY, radius * 0.91, 0, Math.PI * 2);
          context.stroke();
        }

        function drawFinalOrbit(progress, time) {
          var finaleAmount = ease(phase(progress, 0.69, 0.86));
          if (finaleAmount <= 0.001) return;

          var orbitX = (width < 720 ? width * 0.68 : width * 0.77)
            + pointerX * width * 0.018 * pointerInfluence;
          var orbitY = height * 0.36 + pointerY * height * 0.014 * pointerInfluence;
          var orbitRadius = Math.min(width, height) * (width < 720 ? 0.22 : 0.29);
          var bodyRadius = orbitRadius * 0.5;
          var halo = context.createRadialGradient(
            orbitX,
            orbitY,
            bodyRadius * 0.72,
            orbitX,
            orbitY,
            bodyRadius * 2.45
          );
          halo.addColorStop(0, 'rgba(137,211,217,' + (0.2 * finaleAmount).toFixed(3) + ')');
          halo.addColorStop(0.28, 'rgba(84,117,174,' + (0.1 * finaleAmount).toFixed(3) + ')');
          halo.addColorStop(1, 'rgba(7,12,25,0)');
          context.fillStyle = halo;
          context.beginPath();
          context.arc(orbitX, orbitY, bodyRadius * 2.45, 0, Math.PI * 2);
          context.fill();

          context.save();
          context.globalAlpha = 0.82 * finaleAmount;
          context.beginPath();
          context.arc(orbitX, orbitY, bodyRadius, 0, Math.PI * 2);
          context.clip();

          var surface = context.createRadialGradient(
            orbitX + bodyRadius * 0.48,
            orbitY - bodyRadius * 0.42,
            bodyRadius * 0.04,
            orbitX,
            orbitY,
            bodyRadius * 1.2
          );
          surface.addColorStop(0, '#b7dcdd');
          surface.addColorStop(0.2, '#5e8798');
          surface.addColorStop(0.55, '#1a293e');
          surface.addColorStop(1, '#050916');
          context.fillStyle = surface;
          context.fillRect(
            orbitX - bodyRadius,
            orbitY - bodyRadius,
            bodyRadius * 2,
            bodyRadius * 2
          );

          context.fillStyle = 'rgba(1,3,9,0.7)';
          context.beginPath();
          context.arc(
            orbitX - bodyRadius * 0.24,
            orbitY + bodyRadius * 0.04,
            bodyRadius * 1.02,
            0,
            Math.PI * 2
          );
          context.fill();
          context.restore();

          context.strokeStyle = 'rgba(194,234,235,' + (0.42 * finaleAmount).toFixed(3) + ')';
          context.lineWidth = 0.8;
          context.beginPath();
          context.arc(orbitX, orbitY, bodyRadius + 1, -1.3, 1.18);
          context.stroke();

          context.save();
          context.translate(orbitX, orbitY);
          context.rotate(-0.46);
          context.scale(1, 0.38);
          context.strokeStyle = 'rgba(145,208,218,' + (0.2 * finaleAmount).toFixed(3) + ')';
          context.lineWidth = 0.8;
          context.setLineDash([1, 9]);
          context.lineDashOffset = -time * 0.006;
          context.beginPath();
          context.arc(0, 0, orbitRadius, 0, Math.PI * 2);
          context.stroke();
          context.setLineDash([]);

          context.fillStyle = 'rgba(207,228,236,' + (0.72 * finaleAmount).toFixed(3) + ')';
          context.beginPath();
          context.arc(
            Math.cos(time * 0.00012) * orbitRadius,
            Math.sin(time * 0.00012) * orbitRadius,
            2.2,
            0,
            Math.PI * 2
          );
          context.fill();
          context.restore();
        }

        function drawPointerGlow(progress) {
          var glowAmount = band(progress, 0.03, 0.12, 0.72, 0.86) * pointerInfluence;
          if (glowAmount <= 0.001) return;

          var radius = Math.max(130, Math.min(width, height) * 0.24);
          var glow = context.createRadialGradient(
            pointerCanvasX,
            pointerCanvasY,
            0,
            pointerCanvasX,
            pointerCanvasY,
            radius
          );
          glow.addColorStop(0, 'rgba(134,222,224,' + (0.055 * glowAmount).toFixed(3) + ')');
          glow.addColorStop(0.34, 'rgba(91,149,196,' + (0.026 * glowAmount).toFixed(3) + ')');
          glow.addColorStop(1, 'rgba(30,53,93,0)');
          context.fillStyle = glow;
          context.fillRect(0, 0, width, height);
        }

        function drawRipples(time) {
          ripples = ripples.filter(function (ripple) {
            var rippleProgress = (time - ripple.startedAt) / 820;
            if (rippleProgress >= 1) return false;

            var easedProgress = ease(clamp(rippleProgress, 0, 1));
            var radius = 12 + easedProgress * Math.max(width, height) * 0.18;
            var alpha = (1 - easedProgress) * 0.18;
            context.strokeStyle = 'rgba(151,226,228,' + alpha.toFixed(3) + ')';
            context.lineWidth = 0.7 + (1 - easedProgress) * 0.8;
            context.beginPath();
            context.arc(ripple.x, ripple.y, radius, 0, Math.PI * 2);
            context.stroke();
            return true;
          });
        }

        function drawSpace(progress, time) {
          if (!context) return;

          pointerX += (targetPointerX - pointerX) * 0.04;
          pointerY += (targetPointerY - pointerY) * 0.04;
          pointerInfluence += (targetPointerInfluence - pointerInfluence) * 0.055;

          var finaleAmount = ease(phase(progress, 0.69, 0.86));
          var baseCenterX = width * (0.55 - finaleAmount * 0.07);
          var baseCenterY = height * (0.47 - finaleAmount * 0.05);
          var centerX = baseCenterX + pointerX * width * 0.042 * pointerInfluence;
          var centerY = baseCenterY + pointerY * height * 0.034 * pointerInfluence;
          var starCenterX = baseCenterX + pointerX * width * 0.016 * pointerInfluence;
          var starCenterY = baseCenterY + pointerY * height * 0.013 * pointerInfluence;

          var background = context.createRadialGradient(
            centerX,
            centerY,
            0,
            centerX,
            centerY,
            Math.max(width, height) * 0.82
          );
          background.addColorStop(0, finaleAmount > 0.5 ? '#0a1321' : '#0b1828');
          background.addColorStop(0.28, finaleAmount > 0.5 ? '#080c19' : '#08101f');
          background.addColorStop(0.7, '#030710');
          background.addColorStop(1, '#010309');
          context.fillStyle = background;
          context.fillRect(0, 0, width, height);

          var violetGlow = context.createRadialGradient(
            width * 0.25,
            height * 0.82,
            0,
            width * 0.25,
            height * 0.82,
            Math.max(width, height) * 0.58
          );
          violetGlow.addColorStop(0, 'rgba(93,69,151,' + (0.13 + finaleAmount * 0.04).toFixed(3) + ')');
          violetGlow.addColorStop(1, 'rgba(30,25,70,0)');
          context.fillStyle = violetGlow;
          context.fillRect(0, 0, width, height);

          drawPointerGlow(progress);
          drawStarField(progress, time, starCenterX, starCenterY);

          var bodyRadius = Math.min(width, height) * 0.2;
          drawOrbitLines(progress, time, centerX, centerY, bodyRadius);
          drawOrbitDust(progress, time, centerX, centerY, bodyRadius);
          drawCelestialBody(progress, time, centerX, centerY);
          drawPortal(progress, centerX, centerY);
          drawRipples(time);
          drawFinalOrbit(progress, time);
        }

        function renderInterface(progress) {
          var one = band(progress, 0.02, 0.07, 0.13, 0.18);
          var two = band(progress, 0.15, 0.21, 0.28, 0.34);
          var three = band(progress, 0.31, 0.37, 0.47, 0.53);
          var four = band(progress, 0.5, 0.56, 0.65, 0.72);
          var finaleAmount = ease(phase(progress, 0.69, 0.86));

          setLayer(prologues.one, one, (1 - one) * 28, 0.992 + one * 0.008);
          setLayer(prologues.two, two, (1 - two) * 28, 0.992 + two * 0.008);
          setLayer(prologues.three, three, (1 - three) * 28, 0.992 + three * 0.008);
          setLayer(prologues.four, four, (1 - four) * 28, 0.992 + four * 0.008);
          setLayer(finale, finaleAmount, (1 - finaleAmount) * 34, 0.985 + finaleAmount * 0.015);

          finale.style.pointerEvents = finaleAmount > 0.96 ? 'auto' : 'none';
          progressFill.style.transform = 'scaleX(' + progress.toFixed(4) + ')';
          timeLeft.textContent = Math.max(0, Math.ceil((1 - progress) * duration / 1000)) + ' 秒';

          var chapter = '正在唤醒';
          if (progress >= 0.14) chapter = '校准轨道';
          if (progress >= 0.3) chapter = '进入日蚀';
          if (progress >= 0.48) chapter = '穿越光门';
          if (progress >= 0.68) chapter = '已经抵达';

          chapterName.textContent = chapter;
          if (chapter !== lastChapter) {
            lastChapter = chapter;
            status.textContent = chapter;
          }
        }

        function finishSequence() {
          isPlaying = false;
          cancelAnimationFrame(animationFrame);
          currentProgress = 1;
          ripples = [];
          drawSpace(1, performance.now());
          renderInterface(1);
          root.classList.remove('is-playing');
          root.classList.add('is-finished');
          interactionHint.classList.remove('is-visible');
          skipButton.hidden = true;
          replayButton.hidden = reducedMotion.matches;
          status.textContent = '天体序章播放完成，可以进入博客';
        }

        function tick(time) {
          if (!isPlaying) return;

          currentProgress = clamp((time - startedAt) / duration, 0, 1);
          drawSpace(currentProgress, time);
          renderInterface(currentProgress);

          if (currentProgress >= 1) {
            finishSequence();
            return;
          }

          animationFrame = requestAnimationFrame(tick);
        }

        function playSequence() {
          cancelAnimationFrame(animationFrame);
          root.classList.add('is-playing');
          root.classList.remove('is-finished');
          skipButton.hidden = false;
          replayButton.hidden = true;
          currentProgress = 0;
          lastChapter = '';
          ripples = [];
          enterButton.style.removeProperty('--magnet-x');
          enterButton.style.removeProperty('--magnet-y');
          interactionHint.classList.remove('is-visible');
          void interactionHint.offsetWidth;
          interactionHint.classList.add('is-visible');
          startedAt = performance.now();
          isPlaying = true;
          renderInterface(0);
          drawSpace(0, startedAt);
          status.textContent = '天体序章开始播放';
          animationFrame = requestAnimationFrame(tick);
        }

        skipButton.addEventListener('click', finishSequence);
        replayButton.addEventListener('click', playSequence);

        window.addEventListener('pointermove', function (event) {
          if (reducedMotion.matches || event.pointerType === 'touch') return;
          targetPointerX = event.clientX / Math.max(1, width) - 0.5;
          targetPointerY = event.clientY / Math.max(1, height) - 0.5;
          pointerCanvasX = event.clientX;
          pointerCanvasY = event.clientY;
          targetPointerInfluence = 1;
        }, { passive: true });

        root.addEventListener('pointerleave', function () {
          targetPointerX = 0;
          targetPointerY = 0;
          targetPointerInfluence = 0;
        }, { passive: true });

        root.addEventListener('pointerdown', function (event) {
          if (!isPlaying || reducedMotion.matches || event.pointerType === 'touch') return;
          if (event.target.closest && event.target.closest('button, a')) return;
          ripples.push({ x: event.clientX, y: event.clientY, startedAt: performance.now() });
          if (ripples.length > 3) ripples.shift();
        }, { passive: true });

        root.addEventListener('dblclick', function (event) {
          if (!isPlaying) return;
          if (event.target.closest && event.target.closest('button, a')) return;
          event.preventDefault();
          try {
            sessionStorage.setItem(returnKey, returnUrl);
          } catch (error) {}
          window.location.assign(returnUrl);
        });

        enterButton.addEventListener('pointermove', function (event) {
          if (reducedMotion.matches || event.pointerType === 'touch') return;
          var bounds = enterButton.getBoundingClientRect();
          var magnetX = (event.clientX - bounds.left) / bounds.width - 0.5;
          var magnetY = (event.clientY - bounds.top) / bounds.height - 0.5;
          enterButton.style.setProperty('--magnet-x', (magnetX * 7).toFixed(2) + 'px');
          enterButton.style.setProperty('--magnet-y', (magnetY * 5).toFixed(2) + 'px');
        });

        enterButton.addEventListener('pointerleave', function () {
          enterButton.style.removeProperty('--magnet-x');
          enterButton.style.removeProperty('--magnet-y');
        });

        window.addEventListener('resize', resizeCanvas, { passive: true });

        window.addEventListener('keydown', function (event) {
          if (event.key === 'Escape' && isPlaying) finishSequence();
        });

        document.addEventListener('visibilitychange', function () {
          if (document.hidden && isPlaying) {
            cancelAnimationFrame(animationFrame);
            return;
          }

          if (!document.hidden && isPlaying) {
            startedAt = performance.now() - currentProgress * duration;
            animationFrame = requestAnimationFrame(tick);
          }
        });

        reducedMotion.addEventListener('change', function () {
          if (reducedMotion.matches) {
            finishSequence();
            return;
          }

          replayButton.hidden = false;
        });

        resizeCanvas();
        if (reducedMotion.matches) {
          finishSequence();
        } else {
          playSequence();
        }
      })();
    </script>
  </body>
</html>
