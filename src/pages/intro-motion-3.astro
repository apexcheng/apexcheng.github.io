---
import { siteMeta } from '../data/site';
import { withBase } from '../utils/paths';
---

<!doctype html>
<html lang="zh-CN" class="cosmic-opening-page">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="天体序章，以真实地球、太阳光线、行星穿越与太阳系全景为核心的沉浸式 3D 开场。"
    />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#02050d" />
    <link rel="icon" type="image/png" sizes="256x256" href={withBase('/favicon.png?v=5')} />
    <title>天体序章 | {siteMeta.siteName}</title>
  </head>

  <body data-pagefind-ignore>
    <main
      class="cosmic-opening"
      data-cosmic-opening
      data-home-url={withBase('/')}
      data-texture-root={withBase('/images/intro-motion-3')}
      aria-label="天体序章开屏动画"
    >
      <canvas class="cosmic-canvas" data-cosmic-canvas aria-hidden="true"></canvas>
      <div class="cosmic-veil" aria-hidden="true"></div>
      <div class="cosmic-glass" aria-hidden="true"></div>

      <header class="sequence-head">
        <div class="sequence-mark" aria-hidden="true">
          <span class="mark-dot"></span>
          <span>天体序章</span>
          <span class="mark-index">03</span>
        </div>

        <div class="sequence-controls">
          <button class="exit-explore-button" type="button" data-exit-explore hidden>
            返回落版
          </button>
          <button class="skip-button" type="button" data-skip>
            <span>跳过动画</span>
            <span class="skip-arrow" aria-hidden="true"></span>
          </button>
        </div>
      </header>

      <section class="prologue prologue-one" data-prologue="one">
        <p class="prologue-index">坐标 00 / 04</p>
        <p class="prologue-line">每一次记录，</p>
        <p class="prologue-line prologue-line-muted">都从一束微光开始。</p>
      </section>

      <section class="prologue prologue-two" data-prologue="two">
        <p class="prologue-index">坐标 01 / 04</p>
        <p class="prologue-line">迎着太阳的光，</p>
        <p class="prologue-line prologue-line-muted">穿过昼夜与引力。</p>
      </section>

      <section class="prologue prologue-three" data-prologue="three">
        <p class="prologue-index">坐标 02 / 04</p>
        <p class="prologue-line">行星依次经过，</p>
        <p class="prologue-line prologue-line-muted">轨道在黑暗中显出形状。</p>
      </section>

      <section class="prologue prologue-four" data-prologue="four">
        <p class="prologue-index">坐标 03 / 04</p>
        <p class="prologue-line">抵达之前，</p>
        <p class="prologue-line prologue-line-muted">先看一眼完整的太阳系。</p>
      </section>

      <section class="finale" data-finale aria-labelledby="cosmic-title">
        <p class="finale-kicker">个人知识宇宙 · 已抵达</p>
        <h1 id="cosmic-title">
          <span>{siteMeta.authorName}的</span>
          <strong>技术笔记</strong>
        </h1>
        <p class="finale-note">{siteMeta.siteDescription}</p>
        <div class="finale-actions">
          <a class="enter-button" href={withBase('/')} data-enter>
            <span>进入博客</span>
            <span class="enter-orbit" aria-hidden="true"></span>
          </a>
          <button class="explore-button" type="button" data-explore hidden>
            <span>自由探索</span>
            <span class="explore-dot" aria-hidden="true"></span>
          </button>
          <button class="replay-button" type="button" data-replay hidden>重新播放</button>
        </div>
      </section>

      <div class="sequence-foot" aria-hidden="true">
        <span class="chapter-name" data-chapter>正在唤醒</span>
        <div class="progress-track">
          <span class="progress-fill" data-progress></span>
        </div>
        <span class="time-left" data-time>12 秒</span>
      </div>

      <p class="interaction-hint" data-interaction-hint aria-hidden="true">
        <span class="hint-desktop">拖动环视 · 滚轮前后移动 · WASD / QE 飞行</span>
        <span class="hint-mobile">拖动环视</span>
      </p>

      <p class="sr-only" aria-live="polite" data-status>天体序章即将开始</p>

      <noscript>
        <style>
          .cosmic-canvas {
            background:
              radial-gradient(circle at 64% 43%, rgba(79, 131, 183, 0.24), transparent 26%),
              radial-gradient(circle at 36% 66%, rgba(91, 71, 152, 0.2), transparent 32%),
              #02050d;
          }

          .prologue,
          .sequence-foot,
          .skip-button {
            display: none !important;
          }

          .finale {
            opacity: 1 !important;
            pointer-events: auto !important;
            transform: none !important;
            visibility: visible !important;
          }
        </style>
      </noscript>
    </main>

    <style is:inline>
      :root {
        color-scheme: dark;
        font-family:
          Inter, ui-sans-serif, -apple-system, BlinkMacSystemFont, "Segoe UI",
          "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
        font-synthesis: none;
        text-rendering: optimizeLegibility;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        height: 100%;
        margin: 0;
        overflow: hidden;
      }

      body {
        background: #02050d;
        color: #f4f7ff;
      }

      button,
      a {
        color: inherit;
        font: inherit;
      }

      button {
        -webkit-tap-highlight-color: transparent;
      }

      [hidden] {
        display: none !important;
      }

      .cosmic-opening {
        background: #02050d;
        height: 100svh;
        isolation: isolate;
        min-height: 560px;
        overflow: hidden;
        position: relative;
        user-select: none;
        width: 100%;
      }

      .cosmic-canvas {
        background:
          radial-gradient(circle at 64% 42%, rgba(48, 94, 137, 0.2), transparent 30%),
          radial-gradient(circle at 28% 78%, rgba(70, 47, 126, 0.14), transparent 34%),
          #01030a;
        cursor: default;
        display: block;
        height: 100%;
        inset: 0;
        opacity: 0;
        position: absolute;
        touch-action: none;
        transition: opacity 1.1s ease;
        width: 100%;
        z-index: 0;
      }

      .cosmic-opening.is-scene-ready .cosmic-canvas {
        opacity: 1;
      }

      .cosmic-opening.is-scene-ready .cosmic-canvas {
        cursor: grab;
      }

      .cosmic-opening.is-scene-dragging .cosmic-canvas {
        cursor: grabbing;
      }

      .cosmic-veil {
        background:
          radial-gradient(circle at 50% 48%, transparent 20%, rgba(1, 4, 12, 0.14) 56%, rgba(1, 3, 9, 0.72) 112%),
          linear-gradient(180deg, rgba(1, 4, 12, 0.28), transparent 26%, transparent 68%, rgba(1, 4, 12, 0.5));
        inset: 0;
        pointer-events: none;
        position: absolute;
        z-index: 2;
      }

      .cosmic-glass {
        background: linear-gradient(
          112deg,
          transparent 0%,
          rgba(139, 200, 225, 0.025) 42%,
          rgba(255, 255, 255, 0.07) 49.8%,
          transparent 50.2%,
          transparent 100%
        );
        inset: 0;
        opacity: 0.65;
        pointer-events: none;
        transform: translateX(-62%);
        transition: transform 1.8s cubic-bezier(0.2, 0.7, 0.1, 1);
        z-index: 3;
      }

      .cosmic-opening.is-finished .cosmic-glass {
        transform: translateX(55%);
      }

      .sequence-head {
        align-items: center;
        display: flex;
        justify-content: space-between;
        left: max(24px, env(safe-area-inset-left));
        position: absolute;
        right: max(24px, env(safe-area-inset-right));
        top: max(22px, env(safe-area-inset-top));
        z-index: 20;
      }

      .sequence-mark {
        align-items: center;
        color: rgba(218, 230, 244, 0.54);
        display: flex;
        font-size: 11px;
        font-weight: 500;
        gap: 10px;
        letter-spacing: 0.2em;
      }

      .sequence-controls {
        align-items: center;
        display: flex;
        gap: 24px;
      }

      .mark-dot {
        background: #9ce7e0;
        border-radius: 50%;
        box-shadow: 0 0 14px rgba(116, 225, 218, 0.84);
        height: 5px;
        width: 5px;
      }

      .mark-index {
        border-left: 1px solid rgba(206, 222, 239, 0.18);
        color: rgba(218, 230, 244, 0.32);
        padding-left: 10px;
      }

      .skip-button,
      .exit-explore-button,
      .explore-button,
      .replay-button {
        align-items: center;
        background: transparent;
        border: 0;
        cursor: pointer;
        display: inline-flex;
      }

      .skip-button {
        color: rgba(220, 231, 242, 0.54);
        font-size: 12px;
        gap: 12px;
        letter-spacing: 0.12em;
        padding: 10px 0;
        transition: color 220ms ease;
      }

      .skip-button:hover,
      .skip-button:focus-visible {
        color: #ffffff;
      }

      .skip-button:focus-visible,
      .exit-explore-button:focus-visible,
      .explore-button:focus-visible,
      .replay-button:focus-visible,
      .enter-button:focus-visible {
        outline: 1px solid rgba(144, 225, 226, 0.8);
        outline-offset: 6px;
      }

      .skip-arrow {
        border-right: 1px solid currentColor;
        border-top: 1px solid currentColor;
        height: 7px;
        position: relative;
        transform: rotate(45deg);
        width: 7px;
      }

      .skip-arrow::before {
        background: currentColor;
        content: "";
        height: 1px;
        position: absolute;
        right: -2px;
        top: 2px;
        transform: rotate(-45deg);
        transform-origin: right center;
        width: 19px;
      }

      .prologue {
        left: clamp(28px, 8vw, 132px);
        max-width: min(660px, calc(100vw - 56px));
        opacity: 0;
        pointer-events: none;
        position: absolute;
        top: 50%;
        transform: translate3d(0, 28px, 0);
        visibility: hidden;
        z-index: 10;
      }

      .prologue-two {
        left: auto;
        right: clamp(28px, 8vw, 132px);
        text-align: right;
      }

      .prologue-three {
        top: 56%;
      }

      .prologue-four {
        left: auto;
        right: clamp(28px, 9vw, 156px);
        text-align: right;
        top: 44%;
      }

      .prologue-index {
        color: rgba(143, 207, 213, 0.52);
        font-size: 10px;
        font-weight: 500;
        letter-spacing: 0.28em;
        margin: 0 0 16px;
      }

      .prologue-line {
        color: rgba(244, 248, 255, 0.94);
        font-size: clamp(25px, 3vw, 48px);
        font-weight: 420;
        letter-spacing: -0.035em;
        line-height: 1.34;
        margin: 0;
        text-wrap: balance;
      }

      .prologue-line-muted {
        color: rgba(207, 221, 237, 0.48);
        font-size: clamp(18px, 2vw, 31px);
        letter-spacing: -0.02em;
        margin-top: 4px;
      }

      .finale {
        left: clamp(28px, 8vw, 132px);
        max-width: min(760px, calc(100vw - 56px));
        opacity: 0;
        pointer-events: none;
        position: absolute;
        top: 50%;
        transform: translate3d(0, 34px, 0);
        visibility: hidden;
        z-index: 12;
      }

      .cosmic-opening.is-exploring .finale {
        opacity: 0 !important;
        pointer-events: none !important;
        transform: translate3d(0, 20px, 0) scale(0.99) !important;
        visibility: hidden !important;
      }

      .finale-kicker {
        color: rgba(137, 218, 214, 0.72);
        font-size: 11px;
        font-weight: 550;
        letter-spacing: 0.28em;
        margin: 0 0 18px;
      }

      .finale h1 {
        font-size: clamp(48px, 8.7vw, 132px);
        font-weight: 400;
        letter-spacing: -0.065em;
        line-height: 0.92;
        margin: 0;
      }

      .finale h1 span,
      .finale h1 strong {
        display: block;
      }

      .finale h1 span {
        color: rgba(235, 240, 249, 0.58);
        font-size: 0.48em;
        font-weight: 430;
        letter-spacing: -0.035em;
        margin-bottom: 0.12em;
      }

      .finale h1 strong {
        background: linear-gradient(102deg, #f9fbff 4%, #c8e3ec 48%, #d5c4ef 96%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        font-weight: 480;
        padding-bottom: 0.08em;
      }

      .finale-note {
        color: rgba(209, 222, 237, 0.58);
        font-size: clamp(14px, 1.3vw, 18px);
        line-height: 1.8;
        margin: clamp(18px, 3vh, 32px) 0 0;
        max-width: 610px;
      }

      .finale-actions {
        align-items: center;
        display: flex;
        flex-wrap: wrap;
        gap: 24px;
        margin-top: clamp(24px, 4vh, 42px);
      }

      .enter-button {
        --magnet-x: 0px;
        --magnet-y: 0px;
        align-items: center;
        background: rgba(225, 242, 247, 0.94);
        border: 1px solid rgba(255, 255, 255, 0.7);
        border-radius: 999px;
        box-shadow:
          0 16px 54px rgba(60, 147, 163, 0.18),
          inset 0 1px 0 rgba(255, 255, 255, 0.95);
        color: #081117;
        display: inline-flex;
        font-size: 13px;
        font-weight: 650;
        gap: 18px;
        letter-spacing: 0.08em;
        min-height: 50px;
        padding: 0 20px 0 24px;
        text-decoration: none;
        transition:
          box-shadow 260ms ease,
          transform 260ms ease;
        transform: translate3d(var(--magnet-x), var(--magnet-y), 0);
      }

      .enter-button:hover {
        box-shadow:
          0 20px 64px rgba(82, 182, 190, 0.3),
          inset 0 1px 0 rgba(255, 255, 255, 0.95);
        transform: translate3d(var(--magnet-x), calc(var(--magnet-y) - 2px), 0);
      }

      .enter-orbit {
        border: 1px solid rgba(9, 28, 36, 0.36);
        border-radius: 50%;
        height: 22px;
        position: relative;
        transition: transform 720ms cubic-bezier(0.2, 0.75, 0.2, 1);
        width: 22px;
      }

      .enter-button:hover .enter-orbit {
        transform: rotate(112deg);
      }

      .enter-orbit::after {
        background: #0e5f68;
        border-radius: 50%;
        content: "";
        height: 4px;
        position: absolute;
        right: -1px;
        top: 2px;
        width: 4px;
      }

      .replay-button {
        color: rgba(219, 231, 243, 0.55);
        font-size: 12px;
        letter-spacing: 0.11em;
        padding: 12px 0;
        transition: color 220ms ease;
      }

      .replay-button:hover {
        color: #ffffff;
      }

      .explore-button {
        border: 1px solid rgba(189, 219, 231, 0.24);
        border-radius: 999px;
        color: rgba(226, 238, 247, 0.76);
        font-size: 12px;
        gap: 12px;
        letter-spacing: 0.1em;
        min-height: 50px;
        padding: 0 20px;
        transition:
          background 220ms ease,
          border-color 220ms ease,
          color 220ms ease;
      }

      .explore-button:hover {
        background: rgba(151, 213, 221, 0.08);
        border-color: rgba(178, 227, 231, 0.48);
        color: #ffffff;
      }

      .explore-dot {
        background: #8dded8;
        border-radius: 50%;
        box-shadow: 0 0 12px rgba(141, 222, 216, 0.72);
        height: 5px;
        width: 5px;
      }

      .exit-explore-button {
        color: rgba(220, 231, 242, 0.58);
        font-size: 11px;
        letter-spacing: 0.12em;
        padding: 10px 0;
        transition: color 220ms ease;
      }

      .exit-explore-button:hover {
        color: #ffffff;
      }

      .sequence-foot {
        align-items: center;
        bottom: max(24px, env(safe-area-inset-bottom));
        color: rgba(205, 219, 235, 0.36);
        display: grid;
        font-size: 10px;
        gap: 18px;
        grid-template-columns: auto minmax(100px, 240px) 42px;
        left: max(24px, env(safe-area-inset-left));
        letter-spacing: 0.16em;
        position: absolute;
        text-transform: uppercase;
        transition: opacity 280ms ease;
        z-index: 20;
      }

      .cosmic-opening.is-exploring .sequence-foot {
        opacity: 0;
      }

      .chapter-name {
        min-width: 68px;
      }

      .progress-track {
        background: rgba(198, 218, 237, 0.13);
        height: 1px;
        overflow: hidden;
        position: relative;
        width: 100%;
      }

      .progress-fill {
        background: linear-gradient(90deg, #8dded8, #bcc9f2);
        box-shadow: 0 0 10px rgba(135, 220, 215, 0.72);
        display: block;
        height: 100%;
        transform: scaleX(0);
        transform-origin: left center;
        width: 100%;
      }

      .time-left {
        font-variant-numeric: tabular-nums;
        text-align: right;
      }

      .interaction-hint {
        bottom: max(24px, env(safe-area-inset-bottom));
        color: rgba(205, 219, 235, 0.3);
        font-size: 9px;
        letter-spacing: 0.2em;
        margin: 0;
        opacity: 0;
        pointer-events: none;
        position: absolute;
        right: max(24px, env(safe-area-inset-right));
        text-transform: uppercase;
        z-index: 20;
      }

      .interaction-hint.is-visible {
        animation: hint-reveal 3.2s ease 0.35s both;
      }

      .hint-mobile {
        display: none;
      }

      .sr-only {
        clip: rect(0, 0, 0, 0);
        clip-path: inset(50%);
        height: 1px;
        overflow: hidden;
        position: absolute;
        white-space: nowrap;
        width: 1px;
      }

      @media (max-width: 720px) {
        .cosmic-opening {
          min-height: 500px;
        }

        .sequence-head {
          left: max(20px, env(safe-area-inset-left));
          right: max(20px, env(safe-area-inset-right));
          top: max(18px, env(safe-area-inset-top));
        }

        .sequence-mark {
          font-size: 9px;
          gap: 8px;
          letter-spacing: 0.16em;
        }

        .skip-button {
          font-size: 11px;
        }

        .prologue,
        .prologue-two,
        .prologue-three,
        .prologue-four {
          left: 24px;
          max-width: calc(100vw - 48px);
          right: auto;
          text-align: left;
          top: 58%;
        }

        .prologue-two,
        .prologue-four {
          text-align: right;
        }

        .prologue-index {
          font-size: 9px;
          margin-bottom: 12px;
        }

        .prologue-line {
          font-size: clamp(24px, 7.6vw, 34px);
        }

        .prologue-line-muted {
          font-size: clamp(17px, 5vw, 23px);
          line-height: 1.5;
        }

        .finale {
          left: 24px;
          max-width: calc(100vw - 48px);
          top: 49%;
        }

        .finale-kicker {
          font-size: 9px;
          letter-spacing: 0.22em;
          margin-bottom: 14px;
        }

        .finale h1 {
          font-size: clamp(47px, 15vw, 76px);
          letter-spacing: -0.055em;
          line-height: 0.96;
        }

        .finale-note {
          font-size: 13px;
          line-height: 1.7;
          max-width: 330px;
        }

        .finale-actions {
          gap: 14px 18px;
          margin-top: 26px;
        }

        .enter-button,
        .explore-button {
          min-height: 46px;
        }

        .enter-button {
          padding: 0 16px 0 20px;
        }

        .explore-button {
          padding: 0 16px;
        }

        .sequence-foot {
          bottom: max(20px, env(safe-area-inset-bottom));
          gap: 12px;
          grid-template-columns: auto minmax(72px, 1fr) 38px;
          left: max(20px, env(safe-area-inset-left));
          right: max(20px, env(safe-area-inset-right));
        }

        .interaction-hint {
          bottom: max(72px, calc(env(safe-area-inset-bottom) + 48px));
          font-size: 9px;
          left: 20px;
          letter-spacing: 0.16em;
          right: auto;
        }

        .hint-desktop {
          display: none;
        }

        .hint-mobile {
          display: inline;
        }
      }

      @media (max-height: 640px) {
        .prologue,
        .prologue-two,
        .prologue-three,
        .prologue-four {
          top: 48%;
        }

        .finale {
          top: 44%;
        }

        .finale-note {
          margin-top: 14px;
        }

        .finale-actions {
          margin-top: 18px;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .cosmic-glass,
        .enter-button {
          transition: none;
        }

        .interaction-hint {
          display: none;
        }
      }

      @keyframes hint-reveal {
        0%,
        100% {
          opacity: 0;
          transform: translateY(4px);
        }

        18%,
        72% {
          opacity: 1;
          transform: translateY(0);
        }
      }
    </style>

    <script>
      import '../scripts/intro-motion-3.js';
    </script>
  </body>
</html>
