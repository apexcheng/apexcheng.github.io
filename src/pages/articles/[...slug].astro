---
import { getCollection, render } from 'astro:content';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getSeriesMeta } from '../../data/series';
import { siteMeta } from '../../data/site';
import { formatPostDate } from '../../utils/dates';
import { withBase } from '../../utils/paths';

export async function getStaticPaths() {
  const posts = (await getCollection('posts')).filter((post) => !post.data.draft && !post.data.private);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const seriesMeta = post.data.series ? getSeriesMeta(post.data.series) : undefined;
const seriesPosts = post.data.series
  ? (await getCollection('posts'))
      .filter((item) => !item.data.draft && !item.data.private && item.data.series === post.data.series)
      .sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0))
  : [];
const seriesIndex = seriesPosts.findIndex((item) => item.id === post.id);
const previousSeriesPost = seriesIndex > 0 ? seriesPosts[seriesIndex - 1] : undefined;
const nextSeriesPost = seriesIndex >= 0 && seriesIndex < seriesPosts.length - 1 ? seriesPosts[seriesIndex + 1] : undefined;
---

<SiteLayout title={post.data.title} active={post.data.series ? 'series' : 'articles'} description={post.data.description}>
  <main class="page-content article-shell" data-article-shell>
    <div class="article-sidebar" id="article-sidebar">
      <aside class="article-info desktop-article-info">
        <h2>文章信息</h2>
        <p>{post.data.category}</p>
        <p>{formatPostDate(post.data.date)}</p>
        <p>阅读约 {post.data.minutes} 分钟</p>
        <div class="chips">
          {post.data.tags.map((tag) => <span>{tag}</span>)}
        </div>
      </aside>
      <aside class="toc-panel">
        <h2>本文目录</h2>
        {headings.filter((heading) => heading.depth === 2 || heading.depth === 3).map((heading) => (
          <a class={`toc-link toc-link-depth-${heading.depth}`} href={`#${heading.slug}`}>{heading.text}</a>
        ))}
      </aside>
    </div>
    <article class="article-content">
      <div class="article-reading-toolbar">
        <button
          class="article-focus-toggle"
          type="button"
          aria-controls="article-sidebar"
          aria-pressed="false"
          title="隐藏左侧目录，扩大阅读区域"
          data-article-focus-toggle
        >
          <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M8 3H5a2 2 0 0 0-2 2v3"></path>
            <path d="M16 3h3a2 2 0 0 1 2 2v3"></path>
            <path d="M8 21H5a2 2 0 0 1-2-2v-3"></path>
            <path d="M16 21h3a2 2 0 0 0 2-2v-3"></path>
          </svg>
          <span data-article-focus-label>全屏阅读</span>
        </button>
      </div>
      {post.data.series && seriesMeta && seriesIndex >= 0 && (
        <a class="article-series-kicker" href={withBase(`/series/${post.data.series}/`)}>
          <span>系列 · {seriesMeta.title}</span>
          <strong>第 {seriesIndex + 1} 篇 / 共 {seriesPosts.length} 篇</strong>
        </a>
      )}
      <span class="pill">{post.data.category}</span>
      <h1>{post.data.title}</h1>
      <p class="article-description">{post.data.description}</p>
      <div class="meta-row">
        <span>作者：{siteMeta.authorName}</span>
        <span>更新于 {formatPostDate(post.data.updated ?? post.data.date)}</span>
      </div>
      <Content />
      {post.data.series && seriesMeta && seriesIndex >= 0 && (
        <nav class="series-pagination" aria-label={`${seriesMeta.title} 系列导航`}>
          <div class="series-pagination-head">
            <span>继续阅读系列</span>
            <a href={withBase(`/series/${post.data.series}/`)}>{seriesMeta.title}</a>
          </div>
          <div class="series-pagination-links">
            {previousSeriesPost ? (
              <a class="series-pagination-item previous" href={withBase(`/articles/${previousSeriesPost.slug}/`)}>
                <span>← 上一篇</span>
                <strong>{previousSeriesPost.data.title}</strong>
              </a>
            ) : <span class="series-pagination-spacer"></span>}
            {nextSeriesPost ? (
              <a class="series-pagination-item next" href={withBase(`/articles/${nextSeriesPost.slug}/`)}>
                <span>下一篇 →</span>
                <strong>{nextSeriesPost.data.title}</strong>
              </a>
            ) : (
              <div class="series-pagination-complete">
                <span>系列阅读完成</span>
                <strong>✓ 已读到最后一篇</strong>
              </div>
            )}
          </div>
        </nav>
      )}
    </article>
  </main>
  <script src="/scripts/active-toc.js" defer></script>
  <script is:inline>
    (function () {
      var shell = document.querySelector('[data-article-shell]');
      var toggle = document.querySelector('[data-article-focus-toggle]');
      var label = document.querySelector('[data-article-focus-label]');
      var sidebar = document.getElementById('article-sidebar');
      if (!shell || !toggle || !label || !sidebar) return;

      toggle.addEventListener('click', function () {
        var isFocusMode = shell.classList.toggle('is-focus-mode');
        sidebar.setAttribute('aria-hidden', isFocusMode ? 'true' : 'false');
        toggle.setAttribute('aria-pressed', isFocusMode ? 'true' : 'false');
        toggle.setAttribute('title', isFocusMode ? '显示左侧目录' : '隐藏左侧目录，扩大阅读区域');
        label.textContent = isFocusMode ? '退出全屏' : '全屏阅读';
      });
    })();
  </script>
</SiteLayout>
