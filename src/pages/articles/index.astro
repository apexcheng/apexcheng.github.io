---
import { getCollection } from 'astro:content';
import ArticleList from '../../components/ArticleList.astro';
import { categoryMetaList } from '../../data/categories';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { withBase } from '../../utils/paths';

const posts = (await getCollection('posts'))
  .filter((post) => !post.data.draft && !post.data.private)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const defaultPosts = posts.filter((post) => post.data.category !== '视觉实验室' && !post.data.series);
const articlesPageUrl = withBase('/articles/');
const categoryCounts = Object.fromEntries(
  categoryMetaList.map((category) => [category.name, posts.filter((post) => post.data.category === category.name).length]),
);
const tags = Array.from(new Set(posts.flatMap((post) => post.data.tags))).sort((a, b) => a.localeCompare(b));
const tagCounts = Object.fromEntries(tags.map((tag) => [tag, posts.filter((post) => post.data.tags.includes(tag)).length]));
const commonTags = [...tags]
  .sort((a, b) => tagCounts[b] - tagCounts[a] || a.localeCompare(b))
  .slice(0, 15);
const otherTags = tags.filter((tag) => !commonTags.includes(tag));
---

<SiteLayout title="文章列表" active="articles">
  <main class="page-content two-column-page" data-articles-page>
    <aside class="filter-panel">
      <h2>内容分类</h2>
      <a class="active" href={articlesPageUrl} data-category-filter data-category-value="" aria-current="page">
        全部文章 <span>{defaultPosts.length}</span>
      </a>
      {categoryMetaList.map((category) => (
        <a
          href={`${articlesPageUrl}?category=${encodeURIComponent(category.name)}`}
          data-category-filter
          data-category-value={category.name}
        >
          {category.name} <span>{categoryCounts[category.name]}</span>
        </a>
      ))}
      <h2 class="filter-subtitle">常用标签</h2>
      <div class="chips filter-tags" id="article-filter-tags">
        {commonTags.map((tag) => (
          <a href={withBase(`/articles/tag/${encodeURIComponent(tag)}/`)}>{tag}</a>
        ))}
        {otherTags.map((tag) => (
          <a href={withBase(`/articles/tag/${encodeURIComponent(tag)}/`)} data-extra-tag hidden>{tag}</a>
        ))}
      </div>
      {otherTags.length > 0 && (
        <button
          class="filter-tags-toggle"
          type="button"
          data-tags-toggle
          aria-controls="article-filter-tags"
          aria-expanded="false"
        >
          查看全部标签 <span aria-hidden="true">→</span>
        </button>
      )}
    </aside>
    <section>
      <p class="eyebrow">文章</p>
      <h1 class="page-title">文章列表</h1>
      <p class="page-lead">按内容类型、标签和更新时间组织文章。列表页保持轻量，重点是快速扫描标题、摘要和分类。</p>
      <div class="article-sort" aria-label="文章排序">
        <span>排序</span>
        <button class="active" type="button" data-sort-option data-sort-value="date" aria-pressed="true">发布时间</button>
        <button type="button" data-sort-option data-sort-value="updated" aria-pressed="false">修改时间</button>
      </div>
      <div class="search-placeholder">当前共有 {defaultPosts.length} 篇文章、{categoryMetaList.length} 个分类、{tags.length} 个标签；也可以使用顶部导航里的搜索查找内容。</div>
      <ArticleList posts={posts} hideVisualLab hideSeries />
      <p class="article-filter-empty" data-empty-state hidden>当前分类暂无公开文章，请切换到其他分类或查看全部文章。</p>
    </section>
  </main>
  <script is:inline>
    (function () {
      var page = document.querySelector('[data-articles-page]');
      if (!page) return;

      var filters = Array.prototype.slice.call(page.querySelectorAll('[data-category-filter]'));
      var items = Array.prototype.slice.call(page.querySelectorAll('[data-article-item]'));
      var sortOptions = Array.prototype.slice.call(page.querySelectorAll('[data-sort-option]'));
      var list = page.querySelector('[data-article-list]');
      var emptyState = page.querySelector('[data-empty-state]');
      var tagsToggle = page.querySelector('[data-tags-toggle]');
      var extraTags = Array.prototype.slice.call(page.querySelectorAll('[data-extra-tag]'));
      var currentSort = 'date';

      if (tagsToggle) {
        tagsToggle.addEventListener('click', function () {
          var isExpanded = tagsToggle.getAttribute('aria-expanded') === 'true';

          extraTags.forEach(function (tag) {
            tag.hidden = isExpanded;
          });

          tagsToggle.setAttribute('aria-expanded', isExpanded ? 'false' : 'true');
          tagsToggle.innerHTML = isExpanded
            ? '查看全部标签 <span aria-hidden="true">→</span>'
            : '收起标签 <span aria-hidden="true">↑</span>';
        });
      }

      function setActiveFilter(category) {
        var activeFilter = null;

        filters.forEach(function (filter) {
          var isActive = (filter.getAttribute('data-category-value') || '') === category;
          filter.classList.toggle('active', isActive);

          if (isActive) {
            filter.setAttribute('aria-current', 'page');
            activeFilter = filter;
            return;
          }

          filter.removeAttribute('aria-current');
        });

        return activeFilter;
      }

      function updateLastVisibleItem() {
        var lastVisibleItem = null;
        var orderedItems = list ? Array.prototype.slice.call(list.querySelectorAll('[data-article-item]')) : items;

        orderedItems.forEach(function (item) {
          item.classList.remove('is-filtered-last');
          if (!item.hidden) lastVisibleItem = item;
        });

        if (lastVisibleItem) lastVisibleItem.classList.add('is-filtered-last');
      }

      function setActiveSort(sortValue) {
        sortOptions.forEach(function (sortOption) {
          var isActive = sortOption.getAttribute('data-sort-value') === sortValue;
          sortOption.classList.toggle('active', isActive);
          sortOption.setAttribute('aria-pressed', isActive ? 'true' : 'false');
        });
      }

      function applySort(sortValue) {
        if (!list) return;

        setActiveSort(sortValue);

        items
          .slice()
          .sort(function (a, b) {
            var field = sortValue === 'updated' ? 'data-updated-at' : 'data-published-at';
            return Number(b.getAttribute(field) || 0) - Number(a.getAttribute(field) || 0);
          })
          .forEach(function (item) {
            list.appendChild(item);
          });

        updateLastVisibleItem();
      }

      function applyFilter(category, updateUrl) {
        var activeFilter = setActiveFilter(category);
        var visibleCount = 0;

        items.forEach(function (item) {
          var itemCategory = item.getAttribute('data-category') || '';
          var itemSeries = item.getAttribute('data-series') || '';
          var isVisible = category ? itemCategory === category : itemCategory !== '视觉实验室' && !itemSeries;
          item.hidden = !isVisible;
          if (isVisible) visibleCount += 1;
        });

        updateLastVisibleItem();

        if (list) list.hidden = visibleCount === 0;
        if (emptyState) emptyState.hidden = visibleCount !== 0;

        if (updateUrl && activeFilter) {
          history.replaceState(null, '', activeFilter.getAttribute('href') || window.location.pathname);
        }

        applySort(currentSort);
      }

      filters.forEach(function (filter) {
        filter.addEventListener('click', function (event) {
          event.preventDefault();
          applyFilter(filter.getAttribute('data-category-value') || '', true);
        });
      });

      sortOptions.forEach(function (sortOption) {
        sortOption.addEventListener('click', function () {
          currentSort = sortOption.getAttribute('data-sort-value') || 'date';
          applySort(currentSort);
        });
      });

      var initialCategory = '';

      try {
        var requestedCategory = new URLSearchParams(window.location.search).get('category') || '';
        var matchedFilter = filters.some(function (filter) {
          return (filter.getAttribute('data-category-value') || '') === requestedCategory;
        });
        if (matchedFilter) initialCategory = requestedCategory;
      } catch (error) {}

      applyFilter(initialCategory, false);
    })();
  </script>
</SiteLayout>
