---
import { getCollection } from 'astro:content';
import HomeIntroState from '../components/HomeIntroState.astro';
import HomeIndexMenu from '../components/HomeIndexMenu.astro';
import { seriesMetaList } from '../data/series';
import { siteMeta } from '../data/site';
import { withBase } from '../utils/paths';

const posts = (await getCollection('posts'))
  .filter((post) => !post.data.draft && !post.data.private)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const heroPost =
  posts.find((post) => post.slug === 'excel-lookup-functions-visual-guide') ?? posts[0];
const latestPosts = posts.filter((post) => post.data.category !== '视觉实验室').slice(0, 4);
const visualPosts = posts.filter((post) => post.data.category === '视觉实验室').slice(0, 2);

const categoryCards = [
  {
    id: 'life',
    title: '生活',
    description: '记录生活中的观察与思考，把日常过成实验室。',
    href: withBase('/articles/category/' + encodeURIComponent('生活') + '/'),
    linkLabel: '查看最新',
    count: posts.filter((post) => post.data.category === '生活').length,
  },
  {
    id: 'practice',
    title: '实践',
    description: '真实项目与问题实践，从结果回溯到方法。',
    href: withBase('/articles/category/' + encodeURIComponent('实践') + '/'),
    linkLabel: '查看项目',
    count: posts.filter((post) => post.data.category === '实践').length,
  },
  {
    id: 'tutorial',
    title: '教程',
    description: '把复杂的工具与概念，拆解成可操作的步骤。',
    href: withBase('/articles/category/' + encodeURIComponent('教程') + '/'),
    linkLabel: '查看教程',
    count: posts.filter((post) => post.data.category === '教程').length,
  },
  {
    id: 'lab',
    title: '视觉实验室',
    description: '测试文章结构、图表、代码与新的网页表达方式。',
    href: withBase('/articles/category/' + encodeURIComponent('视觉实验室') + '/'),
    linkLabel: '查看实验',
    count: posts.filter((post) => post.data.category === '视觉实验室').length,
  },
];

const seriesCards = seriesMetaList.map((series) => ({
  ...series,
  postCount: posts.filter((post) => post.data.series === series.id).length,
}));

const searchItems = posts.map((post) => ({
  title: post.data.title,
  category: post.data.category,
  description: post.data.description,
  href: withBase('/articles/' + post.slug + '/'),
  keywords: post.data.tags.join(' '),
}));

const formatDate = (date: Date) => date.toISOString().slice(0, 10);
const introHref = `${withBase('/intro-motion-3/')}?return=${encodeURIComponent(withBase('/home-redesign-3/'))}`;
---

<!doctype html>
<html lang="zh-CN" class="home-r3">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="黄撑的个人知识工作台首页原型：记录真实问题、判断过程与可以继续使用的方法。"
    />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#f7f9fd" />
    <link rel="icon" type="image/png" sizes="256x256" href={withBase('/favicon.png?v=5')} />
    <title>首页重设计 · 第三套 | {siteMeta.siteName}</title>
    <script is:inline>
      document.documentElement.classList.add('js');
      try {
        if (localStorage.getItem('home-redesign-3-tone') === 'paper') {
          document.documentElement.dataset.tone = 'paper';
        }
      } catch (error) {}
    </script>
    <HomeIntroState pageKind="standalone" />
  </head>
  <body data-pagefind-ignore>
    <header class="site-header">
      <a class="brand" href="#top" aria-label="返回第三套首页顶部">
        <span class="brand-mark">C</span>
        <strong>{siteMeta.siteName}</strong>
      </a>

      <nav class="main-nav" aria-label="主导航">
        <a class="active" href="#top">首页</a>
        <a href={withBase('/articles/')}>文章</a>
        <a href={withBase('/series/')}>系列</a>
        <a href={withBase('/projects/')}>项目</a>
        <button type="button" data-search-open>搜索</button>
        <a href={withBase('/rss.xml')}>RSS</a>
        <a href={withBase('/about/')}>关于我</a>
      </nav>

      <div class="header-actions">
        <button type="button" data-tone-toggle aria-pressed="false">主题</button>
        <a href={introHref}>开屏</a>
        <HomeIndexMenu current="home-redesign-3" />
      </div>
    </header>

    <main id="top">
      <section class="hero-section">
        <div class="hero-layout">
          <div class="hero-copy" data-reveal>
            <p class="hello">你好，我是黄撑 <span aria-hidden="true">👋</span></p>
            <h1>
              <span>把复杂的事，</span>
              <span>整理成可以继续</span>
              <span class="accent">使用的方法。</span>
            </h1>
            <p class="hero-lead">
              记录真实问题、判断过程和最后的做法，<br />让每一次实践都成为下一次行动的起点。
            </p>
            <div class="hero-actions">
              <a class="button primary" href={withBase('/articles/')}>进入文章库</a>
              <a class="button secondary" href={withBase('/projects/')}>查看项目记录</a>
            </div>
            <p class="today-line">今天是 <time data-current-full-date>今天</time>，继续记录与实践。</p>
          </div>

          <div class="workbench" data-reveal>
            <h2>本周工作台</h2>
            <article class="workbench-feature">
              <div class="feature-copy">
                <span class="tag blue">精选文章</span>
                <h3><a href={withBase('/articles/' + heroPost.slug + '/')}>{heroPost.data.title}</a></h3>
                <p>{heroPost.data.description}</p>
                <div class="feature-meta">
                  <span>{heroPost.data.tags[0]}</span>
                  <span>{formatDate(heroPost.data.date)}</span>
                  <span>{heroPost.data.minutes} 分钟阅读</span>
                </div>
              </div>

              <div class="lookup-demo" aria-label="Excel 查找结果示例">
                <div class="demo-tabs"><b>数据表</b><span>结果预览</span></div>
                <div class="demo-body">
                  <table>
                    <thead><tr><th>产品</th><th>地区</th><th>销量</th></tr></thead>
                    <tbody>
                      <tr><td>键盘</td><td>华东</td><td>1280</td></tr>
                      <tr><td>鼠标</td><td>华南</td><td>980</td></tr>
                      <tr><td>显示器</td><td>华北</td><td>1560</td></tr>
                      <tr><td>耳机</td><td>华东</td><td>760</td></tr>
                      <tr><td>键盘</td><td>华北</td><td>910</td></tr>
                    </tbody>
                  </table>
                  <dl class="lookup-result">
                    <div><dt>产品</dt><dd>键盘</dd></div>
                    <div><dt>地区</dt><dd>华东</dd></div>
                    <div><dt>销量</dt><dd class="result-value">1280</dd></div>
                  </dl>
                </div>
              </div>
            </article>

            <div class="workbench-row">
              <article class="flow-card">
                <div class="card-head"><span class="tag cyan">Agent 流程</span><b>每日复盘 Agent 流程</b></div>
                <ol class="flow-steps" aria-label="Agent 工作流程">
                  <li><span>01</span>收集</li>
                  <li><span>02</span>思考</li>
                  <li><span>03</span>执行</li>
                  <li><span>04</span>记录</li>
                  <li><span>05</span>归档</li>
                </ol>
                <p>持续把想法落地为可复用的步骤。</p>
              </article>

              <article class="project-card">
                <div class="card-head"><span class="tag orange">项目记录</span><b>个人知识库重构计划</b></div>
                <p>整理、打通与沉淀，让知识真正可检索、可复用、可持续。</p>
                <div class="project-progress"><span>进度 45%</span><i><b></b></i></div>
              </article>
            </div>
          </div>
        </div>
      </section>

      <section class="content-section topic-section" aria-labelledby="topics-title">
        <div class="topic-grid">
          {categoryCards.map((category) => (
            <a class:list={['topic-card', category.id]} href={category.href} data-reveal>
              <div class="topic-copy">
                <h2 id={category.id === 'life' ? 'topics-title' : undefined}>{category.title}</h2>
                <p>{category.description}</p>
                <span>{category.linkLabel} · {category.count} 篇</span>
              </div>

              {category.id === 'life' && (
                <img
                  src={withBase('/home-redesign-3/life-workbench.webp')}
                  alt="窗边的笔记本、钢笔与浅绿色咖啡杯"
                  width="960"
                  height="720"
                  loading="lazy"
                />
              )}

              {category.id === 'practice' && (
                <div class="code-card" aria-label="自动化流程代码预览">
                  <pre><code><span>def</span> run_flow(task):
  context = gather(task)
  plan = plan_next(context)
  result = execute(plan)
  return summarize(result)</code></pre>
                  <small>Python · 最近更新 2026-07-17</small>
                </div>
              )}

              {category.id === 'tutorial' && (
                <ol class="tutorial-steps">
                  <li><span>1</span>目标拆解</li>
                  <li><span>2</span>知识准备</li>
                  <li><span>3</span>动手实践</li>
                  <li><span>4</span>总结沉淀</li>
                </ol>
              )}

              {category.id === 'lab' && (
                <div class="lab-preview" aria-label="视觉主题与阅读趋势预览">
                  <div class="swatches"><i></i><i></i><i></i><i></i><i></i><i></i><i></i><i></i></div>
                  <div class="mini-chart">
                    <small>阅读趋势</small>
                    <span style="--height: 30%"></span><span style="--height: 48%"></span>
                    <span style="--height: 42%"></span><span style="--height: 72%"></span>
                    <span style="--height: 60%"></span><span style="--height: 88%"></span>
                    <span style="--height: 68%"></span>
                  </div>
                </div>
              )}
            </a>
          ))}
        </div>
      </section>

      <section class="content-section series-section" id="series" aria-labelledby="series-title">
        <div class="section-head" data-reveal>
          <div><h2 id="series-title">精选系列</h2><p>系统化整理与持续更新的主题集合</p></div>
          <a href={withBase('/series/')}>查看全部系列</a>
        </div>

        <div class="series-grid">
          {seriesCards.map((series, index) => (
            <a class="series-card" href={withBase('/series/' + series.id + '/')} data-reveal>
              <span class:list={['series-mark', 'mark-' + (index + 1)]}>
                {series.id === 'excel-functions' ? 'X' : series.id === 'personal-blog' ? 'KB' : 'A'}
              </span>
              <div>
                <h3>{series.title}</h3>
                <p>{series.description}</p>
              </div>
              <small>{series.postCount} 篇文章</small>
            </a>
          ))}
        </div>
      </section>

      <section class="content-section visual-section" id="visual-lab" aria-labelledby="visual-title">
        <div class="section-head" data-reveal>
          <div><h2 id="visual-title">视觉实验室</h2><p>用页面、图表与交互，把复杂内容讲得更直观</p></div>
          <a href={withBase('/articles/category/' + encodeURIComponent('视觉实验室') + '/')}>全部实验</a>
        </div>

        <div class="visual-grid">
          {visualPosts.map((post, index) => (
            <a class="visual-card" href={withBase('/articles/' + post.slug + '/')} data-reveal>
              <div class="visual-copy">
                <span>视觉实验 · 0{index + 1}</span>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
                <small>{post.data.tags.slice(0, 2).join(' · ')}</small>
              </div>

              {index === 0 ? (
                <div class="formula-panel" aria-label="公式查找路径示例">
                  <p><b>fx</b>=XLOOKUP(E2,A:A,C:C)</p>
                  <table>
                    <tbody>
                      <tr><th>商品</th><th>编码</th><th>结果</th></tr>
                      <tr><td>GK68</td><td>10032</td><td class="hit">已匹配</td></tr>
                      <tr><td>G98</td><td>10047</td><td>待检查</td></tr>
                      <tr><td>X51</td><td>10058</td><td>已匹配</td></tr>
                    </tbody>
                  </table>
                </div>
              ) : (
                <div class="decision-panel" aria-label="目标到验证的决策流程">
                  <span><b>01</b>目标</span>
                  <span><b>02</b>判断</span>
                  <span><b>03</b>执行</span>
                  <span><b>04</b>验证</span>
                </div>
              )}
            </a>
          ))}
        </div>
      </section>

      <section class="content-section latest-section" id="latest" aria-labelledby="latest-title">
        <div class="section-head" data-reveal>
          <div><h2 id="latest-title">最近更新</h2><p>正在持续整理的新内容</p></div>
          <a href={withBase('/articles/')}>进入文章库</a>
        </div>
        <div class="latest-list">
          {latestPosts.map((post, index) => (
            <a class="latest-item" href={withBase('/articles/' + post.slug + '/')} data-reveal>
              <span>0{index + 1}</span>
              <div><small>{post.data.category} · {post.data.tags[0]}</small><h3>{post.data.title}</h3></div>
              <time datetime={formatDate(post.data.date)}>{formatDate(post.data.date)}</time>
              <b>{post.data.minutes} 分钟</b>
            </a>
          ))}
        </div>
      </section>

      <section class="closing-section" data-reveal>
        <div>
          <p>黄撑的个人知识工作台</p>
          <h2>持续记录真实问题、判断过程和最终做法。</h2>
        </div>
        <a class="button primary" href={withBase('/articles/')}>继续阅读</a>
      </section>
    </main>

    <footer>
      <span>© 2026 黄撑</span>
      <nav aria-label="页脚导航">
        <a href={withBase('/series/')}>系列</a>
        <a href={withBase('/projects/')}>项目</a>
        <a href={siteMeta.githubUrl}>GitHub</a>
        <a href={withBase('/about/')}>关于我</a>
      </nav>
    </footer>

    <dialog class="search-dialog" data-search-dialog>
      <form method="dialog" class="search-shell">
        <div class="search-head"><strong>搜索文章</strong><button value="cancel" aria-label="关闭搜索">关闭</button></div>
        <input type="search" placeholder="输入标题、分类或标签" autocomplete="off" data-search-input />
        <div class="search-results" data-search-results></div>
      </form>
    </dialog>

    <script is:inline define:vars={{ searchItems }}>
      (function () {
        var root = document.documentElement;
        var toneToggle = document.querySelector('[data-tone-toggle]');
        var dialog = document.querySelector('[data-search-dialog]');
        var openSearch = document.querySelector('[data-search-open]');
        var searchInput = document.querySelector('[data-search-input]');
        var searchResults = document.querySelector('[data-search-results]');
        var currentDate = document.querySelector('[data-current-full-date]');

        if (currentDate) {
          var now = new Date();
          var dateValue = [
            now.getFullYear(),
            String(now.getMonth() + 1).padStart(2, '0'),
            String(now.getDate()).padStart(2, '0'),
          ].join('-');
          currentDate.textContent = new Intl.DateTimeFormat('zh-CN', {
            year: 'numeric',
            month: '2-digit',
            day: '2-digit',
            weekday: 'long',
          }).format(now);
          currentDate.setAttribute('datetime', dateValue);
        }

        function updateToneButton() {
          if (!toneToggle) return;
          var isPaper = root.dataset.tone === 'paper';
          toneToggle.setAttribute('aria-pressed', String(isPaper));
          toneToggle.title = isPaper ? '切换到晶蓝主题' : '切换到纸张主题';
        }

        if (toneToggle) {
          updateToneButton();
          toneToggle.addEventListener('click', function () {
            var next = root.dataset.tone === 'paper' ? '' : 'paper';
            if (next) root.dataset.tone = next;
            else delete root.dataset.tone;
            updateToneButton();
            try {
              localStorage.setItem('home-redesign-3-tone', next);
            } catch (error) {}
          });
        }

        function escapeHtml(value) {
          return value.replace(/[&<>"]/g, function (character) {
            return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[character];
          });
        }

        function renderResults(query) {
          if (!searchResults) return;
          var normalized = query.trim().toLowerCase();
          var matches = searchItems.filter(function (item) {
            if (!normalized) return true;
            return [item.title, item.category, item.description, item.keywords]
              .join(' ')
              .toLowerCase()
              .includes(normalized);
          }).slice(0, 7);

          searchResults.innerHTML = matches.length
            ? matches.map(function (item) {
                return '<a href="' + item.href + '"><small>' + escapeHtml(item.category) + '</small><strong>'
                  + escapeHtml(item.title) + '</strong><span>' + escapeHtml(item.description) + '</span></a>';
              }).join('')
            : '<p>没有找到匹配文章。</p>';
        }

        if (openSearch && dialog && searchInput) {
          openSearch.addEventListener('click', function () {
            renderResults('');
            dialog.showModal();
            requestAnimationFrame(function () { searchInput.focus(); });
          });
          searchInput.addEventListener('input', function () { renderResults(searchInput.value); });
          dialog.addEventListener('click', function (event) {
            if (event.target === dialog) dialog.close();
          });
        }

        var reveals = Array.from(document.querySelectorAll('[data-reveal]'));
        var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        requestAnimationFrame(function () { root.classList.add('ready'); });

        if (reducedMotion || !('IntersectionObserver' in window)) {
          reveals.forEach(function (element) { element.classList.add('visible'); });
        } else {
          var observer = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
              if (!entry.isIntersecting) return;
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            });
          }, { threshold: 0.12, rootMargin: '0px 0px -7% 0px' });
          reveals.forEach(function (element) { observer.observe(element); });
        }
      })();
    </script>
  </body>
</html>

<style>
  :root {
    --bg: #ffffff;
    --surface: #ffffff;
    --surface-soft: #f7f9fd;
    --ink: #101d36;
    --muted: #53627b;
    --soft: #7b8aa3;
    --line: #dce4f0;
    --line-strong: #c9d5e6;
    --blue: #2161f3;
    --blue-soft: #edf3ff;
    --cyan: #10a7b8;
    --cyan-soft: #e8f9fb;
    --violet: #7657f6;
    --orange: #ff7849;
    --orange-soft: #fff2ec;
    --shadow: 0 18px 44px rgba(33, 73, 128, 0.09);
    --radius: 14px;
    --page-pad: clamp(28px, 3.2vw, 52px);
    --content-width: 1416px;
    color-scheme: light;
    font-family: Inter, ui-sans-serif, -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
    scroll-behavior: smooth;
  }

  :root[data-tone='paper'] {
    --bg: #fbfaf7;
    --surface: #fffefb;
    --surface-soft: #f6f3ec;
    --line: #e5e0d6;
    --line-strong: #d8d0c2;
    --blue-soft: #eef2fa;
  }

  * { box-sizing: border-box; }
  html { background: var(--bg); color: var(--ink); min-width: 320px; text-rendering: optimizeLegibility; }
  body { background: var(--bg); margin: 0; overflow-x: clip; }
  body, button, input { font: inherit; }
  a { color: inherit; text-decoration: none; }
  button { color: inherit; }
  a, button { -webkit-tap-highlight-color: transparent; }
  a:focus-visible, button:focus-visible, input:focus-visible { outline: 3px solid rgba(33, 97, 243, 0.35); outline-offset: 3px; }
  ::selection { background: #cfe0ff; color: #0b2f82; }

  .site-header {
    align-items: center;
    backdrop-filter: blur(18px);
    background: color-mix(in srgb, var(--surface) 92%, transparent);
    border-bottom: 1px solid var(--line);
    display: grid;
    gap: 28px;
    grid-template-columns: minmax(240px, 1fr) auto minmax(160px, 1fr);
    height: 66px;
    padding: 0 var(--page-pad);
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .brand { align-items: center; display: flex; gap: 14px; justify-self: start; }
  .brand-mark {
    align-items: center;
    background: linear-gradient(140deg, #2f72ff, #1557e9);
    border-radius: 10px;
    box-shadow: 0 8px 20px rgba(33, 97, 243, 0.2);
    color: #fff;
    display: inline-flex;
    font-size: 18px;
    font-weight: 700;
    height: 36px;
    justify-content: center;
    width: 36px;
  }
  .brand strong { font-size: 18px; letter-spacing: -0.02em; }

  .main-nav { align-items: stretch; display: flex; gap: 32px; height: 100%; }
  .main-nav a, .main-nav button {
    align-items: center;
    background: transparent;
    border: 0;
    color: #263754;
    cursor: pointer;
    display: flex;
    font-size: 14px;
    padding: 2px 0 0;
    position: relative;
  }
  .main-nav a::after, .main-nav button::after {
    background: var(--blue);
    bottom: 0;
    content: '';
    height: 2px;
    left: 50%;
    position: absolute;
    transform: translateX(-50%) scaleX(0);
    transition: transform 0.2s ease;
    width: 26px;
  }
  .main-nav a:hover::after, .main-nav button:hover::after, .main-nav .active::after { transform: translateX(-50%) scaleX(1); }
  .main-nav .active { color: var(--blue); font-weight: 650; }

  .header-actions {
    --home-index-height: 35px;
    --home-index-radius: 999px;
    --home-index-padding: 15px;
    --home-index-font-size: 13px;
    --home-index-bg: var(--surface);
    --home-index-border: var(--line-strong);
    display: flex;
    gap: 10px;
    justify-self: end;
  }
  .header-actions a, .header-actions button {
