---
import { siteMeta } from '../data/site';
import { openingStageImage } from '../data/intro-motion-1-stage';
import { withBase } from '../utils/paths';
---

<!doctype html>
<html lang="zh-CN" class="opening-page">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="天体序章：黄撑的技术笔记开屏动画原型。" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#020817" />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg?v=3')} />
    <title>天体序章 | {siteMeta.siteName}</title>
  </head>

  <body>
    <main
      class="opening-sequence"
      data-opening-sequence
      data-home-url={withBase('/')}
      aria-label="黄撑的技术笔记开屏动画"
    >
      <div class="stage" aria-hidden="true">
        <img class="stage-image stage-base" data-stage-base src={openingStageImage} alt="" draggable="false" />
        <img class="stage-image stage-orbit" data-stage-orbit src={openingStageImage} alt="" draggable="false" />
        <img class="stage-image stage-focus" data-stage-focus src={openingStageImage} alt="" draggable="false" />
        <img class="stage-image stage-bloom" data-stage-bloom src={openingStageImage} alt="" draggable="false" />
        <canvas class="particle-field" data-particle-field></canvas>
      </div>

      <div class="scene-fade" data-scene-fade aria-hidden="true"></div>

      <button class="skip-control" type="button" data-skip>
        <span data-skip-label>跳过动画</span>
        <span class="skip-rule" aria-hidden="true"></span>
      </button>

      <section class="identity" data-identity aria-labelledby="opening-title">
        <p>个人知识宇宙 · 序章</p>
        <h1 id="opening-title">{siteMeta.siteName}</h1>
      </section>

      <div class="sequence-meta" aria-hidden="true">
        <span class="sequence-index">序列 01</span>
        <span class="sequence-time" data-time>26s</span>
      </div>

      <div class="timeline" aria-hidden="true">
        <span class="timeline-track"></span>
        <span class="timeline-fill" data-progress></span>
      </div>

      <a class="enter-control" href={withBase('/')} data-enter hidden>进入博客</a>
      <button class="replay-control" type="button" data-replay hidden>重新播放</button>
      <p class="sr-only" aria-live="polite" data-status>序章即将开始</p>

      <noscript>
        <style>
          .stage-base,
          .identity,
          .skip-control {
            opacity: 1 !important;
          }

          .scene-fade {
            display: none;
          }
        </style>
      </noscript>
    </main>

    <style is:inline>
      :root {
        color-scheme: dark;
        font-family:
          -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC",
          "Hiragino Sans GB", "Microsoft YaHei", "Noto Sans CJK SC", sans-serif;
        font-synthesis: none;
        text-rendering: optimizeLegibility;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        height: 100%;
        margin: 0;
        overflow: hidden;
      }

      body {
        background: #020817;
        color: #f4f7ff;
      }

      button,
      a {
        font: inherit;
      }

      button {
        -webkit-tap-highlight-color: transparent;
      }

      .opening-sequence {
        background: #020817;
        height: 100svh;
        isolation: isolate;
        min-height: 560px;
        overflow: hidden;
        position: relative;
        width: 100%;
      }

      .stage {
        inset: -5vmax;
        overflow: hidden;
        position: absolute;
        z-index: 0;
      }

      .stage-image {
        height: 100%;
        inset: 0;
        object-fit: cover;
        object-position: 50% 50%;
        pointer-events: none;
        position: absolute;
        transform-origin: 55% 47%;
        user-select: none;
        width: 100%;
        will-change: opacity, transform, filter;
      }

      .stage-base {
        filter: brightness(0.76) saturate(0.9);
        opacity: 0;
      }

      .stage-orbit {
        clip-path: circle(38% at 55% 47%);
        filter: brightness(0.94) saturate(1.08);
        mix-blend-mode: screen;
        opacity: 0;
      }

      .stage-focus {
        clip-path: circle(21% at 55% 47%);
        filter: brightness(1.12) contrast(1.04) saturate(1.18);
        mix-blend-mode: screen;
        opacity: 0;
      }

      .stage-bloom {
        clip-path: circle(14% at 55% 47%);
        filter: blur(18px) brightness(1.34) saturate(1.25);
        mix-blend-mode: screen;
        opacity: 0;
      }

      .particle-field {
        height: 100%;
        inset: 0;
        pointer-events: none;
        position: absolute;
        width: 100%;
      }

      .scene-fade {
        background: #020817;
        inset: 0;
        opacity: 1;
        pointer-events: none;
        position: absolute;
        transition: opacity 720ms cubic-bezier(0.32, 0, 0.18, 1);
        z-index: 20;
      }

      .skip-control,
      .replay-control,
      .enter-control {
        align-items: center;
        background: transparent;
        border: 0;
        color: rgba(225, 233, 250, 0.64);
        cursor: pointer;
        display: inline-flex;
        letter-spacing: 0.12em;
        line-height: 1;
        opacity: 0;
        padding: 12px 0;
        position: absolute;
        text-decoration: none;
        transition:
          color 240ms ease,
          opacity 500ms ease;
        z-index: 30;
      }

      .skip-control {
        font-size: 13px;
        gap: 12px;
        right: clamp(24px, 4.8vw, 76px);
        top: clamp(20px, 4.2vw, 58px);
      }

      .skip-control[hidden],
      .replay-control[hidden],
      .enter-control[hidden] {
        display: none;
      }

      .skip-control:hover,
      .skip-control:focus-visible,
      .replay-control:hover,
      .replay-control:focus-visible,
      .enter-control:hover,
      .enter-control:focus-visible {
        color: #ffffff;
      }

      .skip-control:focus-visible,
      .replay-control:focus-visible,
      .enter-control:focus-visible {
        outline: 1px solid rgba(148, 210, 255, 0.74);
        outline-offset: 8px;
      }

      .skip-rule {
        background: currentColor;
        display: block;
        height: 1px;
        opacity: 0.68;
        position: relative;
        width: 20px;
      }

      .skip-rule::after {
        border-right: 1px solid currentColor;
        border-top: 1px solid currentColor;
        content: "";
        height: 5px;
        position: absolute;
        right: 0;
        top: -2px;
        transform: rotate(45deg);
        width: 5px;
      }

      .identity {
        bottom: clamp(78px, 10vh, 118px);
        left: clamp(28px, 5vw, 76px);
        max-width: min(540px, calc(100vw - 56px));
        opacity: 0;
        position: absolute;
        transform: translateY(24px);
        will-change: opacity, transform;
        z-index: 10;
      }

      .identity p {
        color: rgba(166, 206, 241, 0.58);
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.3em;
        margin: 0 0 12px;
      }

      .identity h1 {
        color: rgba(245, 241, 234, 0.94);
        font-family:
          "Songti SC", "STSong", "Noto Serif CJK SC", "Source Han Serif SC",
          ui-serif, Georgia, serif;
        font-size: clamp(27px, 3vw, 46px);
        font-weight: 400;
        letter-spacing: 0.12em;
        line-height: 1.28;
        margin: 0;
        text-shadow: 0 0 24px rgba(183, 200, 255, 0.12);
      }

      .identity::before {
        background: rgba(159, 187, 255, 0.56);
        content: "";
        display: block;
        height: 1px;
        margin-bottom: 20px;
        width: 112px;
      }

      .sequence-meta {
        bottom: clamp(27px, 3.8vh, 44px);
        color: rgba(180, 198, 226, 0.48);
        display: flex;
        font-size: 10px;
        justify-content: space-between;
        left: clamp(28px, 5vw, 76px);
        letter-spacing: 0.22em;
        position: absolute;
        right: clamp(28px, 5vw, 76px);
        z-index: 10;
      }

      .sequence-time {
        letter-spacing: 0.1em;
      }

      .timeline {
        bottom: clamp(17px, 2.4vh, 29px);
        height: 1px;
        left: clamp(28px, 5vw, 76px);
        overflow: hidden;
        position: absolute;
        right: clamp(28px, 5vw, 76px);
        z-index: 10;
      }

      .timeline-track,
      .timeline-fill {
        inset: 0;
        position: absolute;
        transform-origin: left center;
      }

      .timeline-track {
        background: rgba(179, 197, 226, 0.14);
      }

      .timeline-fill {
        background: rgba(154, 205, 255, 0.76);
        transform: scaleX(0);
        will-change: transform;
      }

      .replay-control,
      .enter-control {
        bottom: 66px;
        font-size: 11px;
      }

      .replay-control {
        right: clamp(28px, 5vw, 76px);
      }

      .enter-control {
        right: calc(clamp(28px, 5vw, 76px) + 92px);
      }

      .replay-control:not([hidden]),
      .enter-control:not([hidden]) {
        opacity: 1;
      }

      .sr-only {
        clip: rect(0 0 0 0);
        clip-path: inset(50%);
        height: 1px;
        overflow: hidden;
        position: absolute;
        white-space: nowrap;
        width: 1px;
      }

      @media (max-width: 720px) {
        .opening-sequence {
          min-height: 480px;
        }

        .stage {
          inset: -10vmax;
        }

        .stage-image {
          object-position: 54% 50%;
          transform-origin: 54% 48%;
        }

        .stage-orbit {
          clip-path: circle(42% at 54% 48%);
        }

        .stage-focus {
          clip-path: circle(24% at 54% 48%);
        }

        .stage-bloom {
          clip-path: circle(17% at 54% 48%);
        }

        .skip-control {
          font-size: 12px;
          right: 22px;
          top: 20px;
        }

        .identity {
          bottom: 88px;
          left: 24px;
          max-width: calc(100vw - 48px);
        }

        .identity p {
          font-size: 10px;
          letter-spacing: 0.22em;
        }

        .identity h1 {
          font-size: clamp(26px, 8vw, 36px);
          letter-spacing: 0.08em;
        }

        .identity::before {
          margin-bottom: 16px;
          width: 78px;
        }

        .sequence-meta {
          bottom: 34px;
          left: 24px;
          right: 24px;
        }

        .timeline {
          bottom: 23px;
          left: 24px;
          right: 24px;
        }

        .replay-control {
          bottom: 58px;
          right: 24px;
        }

        .enter-control {
          bottom: 58px;
          right: 116px;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .stage-orbit,
        .stage-focus,
        .stage-bloom,
        .particle-field {
          display: none;
        }

        .stage-base {
          filter: brightness(0.82) saturate(0.94);
          opacity: 1 !important;
          transform: scale(1.04) !important;
        }

        .identity,
        .skip-control {
          opacity: 1 !important;
          transform: none !important;
        }

        .scene-fade {
          opacity: 0 !important;
          transition: none;
        }

        .timeline-fill {
          transform: scaleX(1) !important;
        }
      }
    </style>

    <script is:inline>
      (function () {
        var root = document.querySelector('[data-opening-sequence]');
        if (!root) return;

        var base = root.querySelector('[data-stage-base]');
        var orbit = root.querySelector('[data-stage-orbit]');
        var focus = root.querySelector('[data-stage-focus]');
        var bloom = root.querySelector('[data-stage-bloom]');
        var canvas = root.querySelector('[data-particle-field]');
        var fade = root.querySelector('[data-scene-fade]');
        var identity = root.querySelector('[data-identity]');
        var progress = root.querySelector('[data-progress]');
        var time = root.querySelector('[data-time]');
        var skip = root.querySelector('[data-skip]');
        var skipLabel = root.querySelector('[data-skip-label]');
        var replay = root.querySelector('[data-replay]');
        var enter = root.querySelector('[data-enter]');
        var status = root.querySelector('[data-status]');
        var params = new URLSearchParams(window.location.search);
        var returnKey = 'site-intro-return-v1';
        var requestedSeconds = Number(params.get('duration'));
        var total = Number.isFinite(requestedSeconds) && requestedSeconds >= 3
          ? Math.min(requestedSeconds, 30) * 1000
          : 26000;
        var previewPeak = params.get('frame') === 'peak';
        var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        var finePointer = window.matchMedia('(pointer: fine)').matches;
        var start = performance.now();
        var pausedAt = 0;
        var pointerX = 0;
        var pointerY = 0;
        var currentStage = '';
        var frameId = 0;
        var finishing = false;
        var points = [];
        var context = canvas.getContext('2d', { alpha: true });
        var viewportWidth = 0;
        var viewportHeight = 0;
        var pixelRatio = 1;

        function resolveReturnUrl(value) {
          try {
            var target = new URL(value || root.dataset.homeUrl, window.location.origin);
            if (target.origin !== window.location.origin) return root.dataset.homeUrl;
            return target.pathname + target.search + target.hash;
          } catch (error) {
            return root.dataset.homeUrl;
          }
        }

        var returnUrl = resolveReturnUrl(params.get('return'));
        enter.href = returnUrl;

        function clamp(value, min, max) {
          return Math.max(min, Math.min(max, value));
        }

        function smooth(value) {
          var n = clamp(value, 0, 1);
          return n * n * (3 - 2 * n);
        }

        function phase(progressValue, from, to) {
          return smooth((progressValue - from) / (to - from));
        }

        function setStage(message) {
          if (message === currentStage) return;
          currentStage = message;
          status.textContent = message;
        }

        function resizeCanvas() {
          var rect = root.getBoundingClientRect();
          viewportWidth = rect.width;
          viewportHeight = rect.height;
          pixelRatio = Math.min(window.devicePixelRatio || 1, 1.5);
          canvas.width = Math.max(1, Math.round(viewportWidth * pixelRatio));
          canvas.height = Math.max(1, Math.round(viewportHeight * pixelRatio));
          canvas.style.width = viewportWidth + 'px';
          canvas.style.height = viewportHeight + 'px';
          context.setTransform(pixelRatio, 0, 0, pixelRatio, 0, 0);

          var count = viewportWidth < 720 ? 30 : 62;
          points = Array.from({ length: count }, function (_, index) {
            return {
              angle: (index / count) * Math.PI * 2 + Math.random() * 0.5,
              radius: 0.13 + Math.random() * 0.42,
              speed: 0.000018 + Math.random() * 0.000034,
              size: 0.45 + Math.random() * 1.2,
              depth: 0.25 + Math.random() * 0.75,
              drift: (Math.random() - 0.5) * 18,
            };
          });
        }

        function drawParticles(now, reveal, align, exitAmount) {
          context.clearRect(0, 0, viewportWidth, viewportHeight);
          if (reducedMotion) return;

          var centerX = viewportWidth * (viewportWidth < 720 ? 0.54 : 0.55);
          var centerY = viewportHeight * 0.47;
          var radiusX = Math.min(viewportWidth, viewportHeight * 1.35);
          var radiusY = radiusX * 0.48;

          context.save();
          context.globalCompositeOperation = 'screen';

          points.forEach(function (point, index) {
            var angle = point.angle + now * point.speed * (index % 2 ? 1 : -1);
            var x = centerX + Math.cos(angle) * radiusX * point.radius + pointerX * point.depth;
            var y = centerY + Math.sin(angle) * radiusY * point.radius + point.drift + pointerY * point.depth;
            var pulse = 0.45 + Math.sin(now * 0.0012 + index) * 0.25;
            var alpha = reveal * (0.12 + point.depth * 0.34) * pulse * (1 - exitAmount);

            context.beginPath();
            context.fillStyle = index % 5 === 0
              ? 'rgba(190, 174, 255,' + alpha + ')'
              : 'rgba(115, 210, 255,' + alpha + ')';
            context.arc(x, y, point.size * (0.7 + align * 0.45), 0, Math.PI * 2);
            context.fill();
          });

          context.restore();
        }

        function render(value, now) {
          var p = clamp(value, 0, 1);
          var reveal = phase(p, 0.02, 0.24);
          var orbitWake = phase(p, 0.18, 0.46);
          var alignment = phase(p, 0.34, 0.67);
          var eclipse = phase(p, 0.58, 0.73);
          var titleIn = phase(p, 0.7, 0.84);
          var exitAmount = 0;
          var openingFade = 1 - phase(p, 0, 0.09);
          var parallaxX = pointerX * 0.8;
          var parallaxY = pointerY * 0.8;

          base.style.opacity = String(0.06 + reveal * 0.94);
          base.style.transform =
            'translate3d(' + (parallaxX - alignment * 4) + 'px,' +
            (parallaxY - alignment * 2) + 'px,0) scale(' +
            (1.17 - reveal * 0.065 - alignment * 0.025) + ')';

          orbit.style.opacity = String(orbitWake * (0.18 + eclipse * 0.2) * (1 - exitAmount));
          orbit.style.transform =
            'translate3d(' + (pointerX * 1.7) + 'px,' + (pointerY * 1.45) +
            'px,0) rotate(' + (-1.7 + alignment * 4.2) + 'deg) scale(' +
            (1.1 - alignment * 0.025) + ')';

          focus.style.opacity = String(alignment * (0.1 + eclipse * 0.4) * (1 - exitAmount));
          focus.style.transform =
            'translate3d(' + (pointerX * 2.4) + 'px,' + (pointerY * 2) +
            'px,0) rotate(' + (1.1 - alignment * 2.1) + 'deg) scale(' +
            (1.08 - eclipse * 0.035) + ')';

          var pulse = Math.max(0, Math.sin(phase(p, 0.59, 0.76) * Math.PI));
          bloom.style.opacity = String(pulse * 0.52 * (1 - exitAmount));
          bloom.style.transform =
            'translate3d(' + (pointerX * 2.8) + 'px,' + (pointerY * 2.2) +
            'px,0) scale(' + (1.02 + pulse * 0.08) + ')';

          identity.style.opacity = String(titleIn * (1 - exitAmount));
          identity.style.transform = 'translateY(' + ((1 - titleIn) * 24) + 'px)';
          skip.style.opacity = String(phase(p, 0.05, 0.16) * (1 - exitAmount));
          progress.style.transform = 'scaleX(' + p + ')';
          fade.style.opacity = String(Math.max(openingFade, exitAmount));
          time.textContent = Math.max(0, Math.ceil((total * (1 - p)) / 1000)) + 's';

          drawParticles(now, reveal, alignment, exitAmount);

          if (p < 0.2) setStage('序章开始，第一束信号正在出现');
          else if (p < 0.48) setStage('环轨正在逐层苏醒');
          else if (p < 0.72) setStage('天体结构正在对齐');
          else if (p < 0.95) setStage('黄撑的技术笔记正在显现');
          else setStage('序章播放完毕');
        }

        function completeSequence() {
          if (finishing) return;
          finishing = true;
          window.cancelAnimationFrame(frameId);
          render(1, performance.now());
          skip.hidden = true;
          enter.hidden = false;
          replay.hidden = false;
          setStage('序章播放完毕，可以进入博客或重新播放');
        }

        function tick(now) {
          var elapsed = now - start;
          var p = clamp(elapsed / total, 0, 1);
          render(p, now);

          if (p < 1) {
            frameId = window.requestAnimationFrame(tick);
            return;
          }

          completeSequence();
        }

        function restart() {
          finishing = false;
          skip.hidden = false;
          skipLabel.textContent = '跳过动画';
          enter.hidden = true;
          replay.hidden = true;
          start = performance.now();
          pointerX = 0;
          pointerY = 0;
          render(0, start);
          frameId = window.requestAnimationFrame(tick);
        }

        skip.addEventListener('click', function () {
          completeSequence();
        });

        replay.addEventListener('click', restart);
        enter.addEventListener('click', function () {
          try {
            sessionStorage.setItem(returnKey, returnUrl);
          } catch (error) {}
        });

        document.addEventListener('keydown', function (event) {
          if (event.key === 'Escape') {
            completeSequence();
          }

          if ((event.key === 'r' || event.key === 'R') && finishing && !reducedMotion) {
            restart();
          }
        });

        if (finePointer && !reducedMotion) {
          root.addEventListener('pointermove', function (event) {
            pointerX = ((event.clientX / window.innerWidth) - 0.5) * 8;
            pointerY = ((event.clientY / window.innerHeight) - 0.5) * 6;
          });

          root.addEventListener('pointerleave', function () {
            pointerX = 0;
            pointerY = 0;
          });
        }

        document.addEventListener('visibilitychange', function () {
          if (document.hidden) {
            pausedAt = performance.now();
            window.cancelAnimationFrame(frameId);
            return;
          }

          if (pausedAt && !finishing && !reducedMotion && !previewPeak) {
            start += performance.now() - pausedAt;
            pausedAt = 0;
            frameId = window.requestAnimationFrame(tick);
          }
        });

        window.addEventListener('resize', resizeCanvas, { passive: true });
        resizeCanvas();

        if (reducedMotion) {
          skip.hidden = true;
          enter.hidden = false;
          render(1, performance.now());
          setStage('已显示静态序章画面');
          return;
        }

        if (previewPeak) {
          render(0.78, performance.now());
          enter.hidden = false;
          replay.hidden = false;
          setStage('序章关键画面预览');
          return;
        }

        render(0, start);
        frameId = window.requestAnimationFrame(tick);
      })();
    </script>
  </body>
</html>

