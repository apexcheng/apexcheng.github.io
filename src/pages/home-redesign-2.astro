---
import { getCollection } from 'astro:content';
import HomeIndexMenu from '../components/HomeIndexMenu.astro';
import { categoryMetaList } from '../data/categories';
import { seriesMetaList } from '../data/series';
import { siteMeta } from '../data/site';
import { withBase } from '../utils/paths';

const posts = (await getCollection('posts'))
  .filter((post) => !post.data.draft && !post.data.private)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const latestPosts = posts.filter((post) => post.data.category !== '视觉实验室').slice(0, 3);
const archivePosts = posts.filter((post) => post.data.category !== '视觉实验室').slice(0, 6);
const visualPosts = posts.filter((post) => post.data.category === '视觉实验室').slice(0, 3);

const categoryDetails = [
  {
    id: 'life',
    name: '生活',
    accent: 'coral',
    description: '记录生活判断与思考',
    action: '阅读生活笔记',
  },
  {
    id: 'practice',
    name: '实践',
    accent: 'cyan',
    description: '真实项目复盘与技术实现',
    action: '查看实践记录',
  },
  {
    id: 'tutorial',
    name: '教程',
    accent: 'coral',
    description: '系统化方法与步骤拆解',
    action: '浏览教程',
  },
  {
    id: 'lab',
    name: '视觉实验室',
    accent: 'cyan',
    description: '图表、代码与页面的表达实验',
    action: '进入实验室',
  },
].map((category) => ({
  ...category,
  href: withBase(`/articles/category/${encodeURIComponent(category.name)}/`),
  count: posts.filter((post) => post.data.category === category.name).length,
}));

const featuredSeries = seriesMetaList.map((series) => ({
  ...series,
  count: posts.filter((post) => post.data.series === series.id).length,
  href: withBase(`/series/${series.id}/`),
}));

const searchItems = posts.map((post) => ({
  title: post.data.title,
  description: post.data.description,
  category: post.data.category,
  href: withBase(`/articles/${post.slug}/`),
  keywords: post.data.tags.join(' '),
}));

const formatDate = (date: Date) => date.toISOString().slice(0, 10);
const paperTexture = withBase('/images/home-redesign-2/paper-texture.webp');
const linedPaper = withBase('/images/home-redesign-2/lined-paper.webp');
const gridPaper = withBase('/images/home-redesign-2/grid-paper.webp');
---

<!doctype html>
<html lang="zh-CN" class="paper-page">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="黄撑的技术笔记首页重设计第二套：以纸张、手记和真实工作痕迹组织生活、实践、教程与视觉实验。"
    />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#f8f4eb" />
    <link rel="icon" type="image/png" sizes="256x256" href={withBase('/favicon.png?v=4')} />
    <title>首页方案二 · 纸张手记 | {siteMeta.siteName}</title>
    <script is:inline>
      document.documentElement.classList.add('js');
      try {
        if (localStorage.getItem('home-redesign-2-theme') === 'night') {
          document.documentElement.dataset.paperTheme = 'night';
        }
      } catch (error) {}
    </script>
  </head>
  <body
    data-pagefind-ignore
    style={`--paper-texture: url("${paperTexture}"); --lined-paper: url("${linedPaper}"); --grid-paper: url("${gridPaper}");`}
  >
    <header class="paper-header">
      <div class="header-inner">
        <a class="paper-brand" href="#top" aria-label="返回方案二顶部">
          <span class="brand-mark">C</span>
          <strong>{siteMeta.siteName}</strong>
        </a>

        <nav class="paper-nav" aria-label="主导航">
          <a class="active" href={withBase('/')}>首页</a>
          <a href={withBase('/articles/')}>文章</a>
          <a href={withBase('/series/')}>系列</a>
          <a href={withBase('/projects/')}>项目</a>
          <button type="button" data-search-open>搜索</button>
          <a href={withBase(siteMeta.rssPath)}>RSS</a>
          <a href={withBase('/about/')}>关于我</a>
        </nav>

        <div class="header-actions">
          <button class="header-button" type="button" data-theme-toggle aria-label="切换纸张明暗主题">
            主题
          </button>
          <div class="intro-picker" data-intro-picker>
            <button
              class="header-button"
              type="button"
              aria-expanded="false"
              aria-controls="paper-intro-menu"
              data-intro-toggle
            >开屏</button>
            <div class="intro-menu" id="paper-intro-menu" role="menu">
              <a role="menuitem" href={withBase('/intro-motion-2/')}>液态字场</a>
              <a role="menuitem" href={withBase('/intro-motion-3/')}>天体序章</a>
            </div>
          </div>
          <HomeIndexMenu current="home-redesign-2" />
        </div>
      </div>
    </header>

    <main id="top">
      <section class="paper-hero shell">
        <div class="hero-copy" data-reveal>
          <p class="hand-note">记录生活判断，沉淀可复用的方法</p>
          <h1>把真实问题，拆成<br /><span>看得懂、做得到</span>的方法。</h1>
          <p class="hero-lead">
            这里记录生活里的判断、真实项目中的技术实践，<br class="desktop-only" />以及不断整理完善的方法。
          </p>
          <div class="hero-actions">
            <a class="primary-action" href={withBase('/articles/')}>开始阅读</a>
            <a class="text-action" href={withBase('/series/')}>查看系列 <span aria-hidden="true">→</span></a>
          </div>
        </div>

        <aside class="recent-board" aria-label="最近在做" data-reveal>
          <h2>最近在做</h2>
          <div class="ink-stroke" aria-hidden="true"></div>
          <div class="recent-list">
            {latestPosts.map((post, index) => (
              <a class="recent-item" href={withBase(`/articles/${post.slug}/`)}>
                <span class:list={['recent-dot', index === 1 ? 'coral' : 'cyan']} aria-hidden="true"></span>
                <div>
                  <div class="recent-title-row">
                    <h3>{post.data.title}</h3>
                    <time datetime={formatDate(post.data.date)}>{formatDate(post.data.date)}</time>
                  </div>
                  <p>{post.data.description}</p>
                </div>
              </a>
            ))}
          </div>
          <a class="small-link" href={withBase('/articles/')}>查看全部动态 <span aria-hidden="true">→</span></a>
        </aside>
      </section>

      <section class="direction-section shell" aria-labelledby="direction-title">
        <div class="section-hand-label" id="direction-title">正在持续整理</div>
        <div class="direction-board" data-reveal>
          <article class="direction-card direction-life">
            <div class="direction-heading">
              <h2>生活 <span>/</span></h2>
              <p>记录生活判断与思考</p>
            </div>
            <div class="paper-visual lined-note" aria-hidden="true">
              <span class="note-date">2026-07-18</span>
              <p>把一天的注意力，<br />放在最重要的三件事上。</p>
            </div>
            <a href={categoryDetails[0].href}>{categoryDetails[0].action} <span aria-hidden="true">→</span></a>
          </article>

          <article class="direction-card direction-practice">
            <div class="direction-heading">
              <h2>实践 <span>/</span></h2>
              <p>真实项目复盘与技术实现</p>
            </div>
            <div class="code-sheet" aria-label="Agent 实践代码片段">
              <pre><code><span class="line-no">1</span> <span class="code-blue">from</span> agent <span class="code-blue">import</span> run_agent
<span class="line-no">2</span> <span class="code-blue">from</span> rpa <span class="code-blue">import</span> run_flow
<span class="line-no">3</span> <span class="code-blue">from</span> notes <span class="code-blue">import</span> publish
<span class="line-no">4</span>
<span class="line-no">5</span> TODAY = [<span class="code-green">"pricing"</span>, <span class="code-green">"stock"</span>]
<span class="line-no">6</span>
<span class="line-no">7</span> <span class="code-blue">for</span> task <span class="code-blue">in</span> TODAY:
<span class="line-no">8</span>     result = run_agent(task)
<span class="line-no">9</span>     publish(run_flow(result))</code></pre>
            </div>
            <a href={categoryDetails[1].href}>{categoryDetails[1].action} <span aria-hidden="true">→</span></a>
          </article>

          <article class="direction-card direction-tutorial">
            <div class="direction-heading">
              <h2>教程 <span>/</span></h2>
              <p>系统化方法与步骤拆解</p>
            </div>
            <div class="paper-visual grid-note" aria-hidden="true">
              <strong>工作流设计清单</strong>
              <ol>
                <li>明确目标与边界</li>
                <li>输入 / 输出定义</li>
                <li>分解任务与依赖</li>
                <li>选择工具与顺序</li>
                <li>验证与迭代</li>
              </ol>
            </div>
            <a href={categoryDetails[2].href}>{categoryDetails[2].action} <span aria-hidden="true">→</span></a>
          </article>

          <article class="direction-card direction-lab">
            <div class="direction-heading">
              <h2>视觉实验室</h2>
              <p>图表、代码与页面的表达实验</p>
            </div>
            <div class="sheet-preview" aria-label="表格与图表预览">
              <div class="mini-table">
                <div class="table-head"><span>主题</span><span>状态</span><span>进度</span></div>
                <div><span>Agent 工作流</span><span>进行中</span><b>60%</b></div>
                <div><span>内容自动化</span><span>设计中</span><b>45%</b></div>
                <div><span>知识图谱卡片</span><span>设计中</span><b>30%</b></div>
              </div>
              <div class="mini-chart" aria-hidden="true">
                <i style="--value: 38%"></i><i style="--value: 62%"></i><i style="--value: 82%"></i><i style="--value: 55%"></i>
              </div>
            </div>
            <a href={categoryDetails[3].href}>{categoryDetails[3].action} <span aria-hidden="true">→</span></a>
          </article>
        </div>
      </section>

      <section class="series-section shell" id="series">
        <div class="section-heading" data-reveal>
          <div>
            <p class="hand-note">把零散内容，整理成一条路线</p>
            <h2>正在形成的阅读系列</h2>
          </div>
          <a href={withBase('/series/')}>查看全部系列 <span aria-hidden="true">→</span></a>
        </div>

        <div class="series-grid">
          {featuredSeries.map((series, index) => (
            <a class:list={['series-folder', index === 1 && 'cyan', index === 2 && 'blue']} href={series.href} data-reveal>
              <div class="folder-tab">系列 {String(index + 1).padStart(2, '0')}</div>
              <div class="folder-meta">
                <span>{series.count} 篇文章</span>
                <span>持续更新</span>
              </div>
              <h3>{series.title}</h3>
              <p>{series.description}</p>
              <span class="folder-action">打开阅读路线 <i aria-hidden="true">→</i></span>
            </a>
          ))}
        </div>
      </section>

      <section class="lab-section shell" id="visual-lab">
        <div class="section-heading" data-reveal>
          <div>
            <p class="hand-note cyan-note">把复杂关系，画到一眼能懂</p>
            <h2>最近的视觉实验</h2>
          </div>
          <a href={categoryDetails[3].href}>进入视觉实验室 <span aria-hidden="true">→</span></a>
        </div>

        <div class="lab-list">
          {visualPosts.map((post, index) => (
            <a class="lab-row" href={withBase(`/articles/${post.slug}/`)} data-reveal>
              <span class="lab-index">0{index + 1}</span>
              <div class="lab-copy">
                <span>{post.data.tags.slice(0, 2).join(' · ')}</span>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
              </div>
              <div class:list={['lab-swatch', index === 1 && 'coral', index === 2 && 'ink']} aria-hidden="true">
                <i></i><i></i><i></i>
              </div>
              <span class="lab-arrow" aria-hidden="true">→</span>
            </a>
          ))}
        </div>
      </section>

      <section class="archive-section shell" id="latest">
        <div class="section-heading" data-reveal>
          <div>
            <p class="hand-note">最近写下来的内容</p>
            <h2>文章归档</h2>
          </div>
          <a href={withBase('/articles/')}>浏览全部文章 <span aria-hidden="true">→</span></a>
        </div>

        <div class="archive-list">
          {archivePosts.map((post, index) => (
            <a class="archive-row" href={withBase(`/articles/${post.slug}/`)} data-reveal>
              <span class="archive-no">{String(index + 1).padStart(2, '0')}</span>
              <div>
                <span class="archive-category">{post.data.category}</span>
                <h3>{post.data.title}</h3>
              </div>
              <p>{post.data.description}</p>
              <time datetime={formatDate(post.data.date)}>{formatDate(post.data.date)}</time>
              <span aria-hidden="true">↗</span>
            </a>
          ))}
        </div>
      </section>

      <section class="closing-section shell" data-reveal>
        <p>持续记录真实问题、判断过程和最后做法。</p>
        <a href={withBase('/articles/')}>从最新一篇开始 <span aria-hidden="true">→</span></a>
      </section>
    </main>

    <footer class="paper-footer">
      <div class="shell">
        <span>© 2026 黄撑</span>
        <span>个人记录 · 真实实践 · 持续整理</span>
        <a href={siteMeta.githubUrl}>GitHub ↗</a>
      </div>
    </footer>

    <div class="search-overlay" data-search-overlay aria-hidden="true">
      <button class="search-backdrop" type="button" aria-label="关闭搜索" data-search-close></button>
      <section class="search-sheet" role="dialog" aria-modal="true" aria-labelledby="search-title">
        <div class="search-head">
          <div>
            <p class="hand-note">在手记里找一找</p>
            <h2 id="search-title">搜索文章</h2>
          </div>
          <button type="button" data-search-close>关闭</button>
        </div>
        <input
          type="search"
          placeholder="输入标题、分类或关键词"
          autocomplete="off"
          aria-label="搜索文章"
          data-search-input
        />
        <div
          class="search-results"
          data-search-results
          data-items={JSON.stringify(searchItems)}
          data-all-articles={withBase('/articles/')}
          aria-live="polite"
        ></div>
      </section>
    </div>

    <script is:inline>
      (function () {
        var root = document.documentElement;
        var themeToggle = document.querySelector('[data-theme-toggle]');
        var introPicker = document.querySelector('[data-intro-picker]');
        var introToggle = document.querySelector('[data-intro-toggle]');
        var searchOverlay = document.querySelector('[data-search-overlay]');
        var searchInput = document.querySelector('[data-search-input]');
        var searchResults = document.querySelector('[data-search-results]');
        var searchOpeners = document.querySelectorAll('[data-search-open]');
        var searchClosers = document.querySelectorAll('[data-search-close]');

        function setNight(isNight) {
          root.dataset.paperTheme = isNight ? 'night' : 'day';
          try {
            localStorage.setItem('home-redesign-2-theme', isNight ? 'night' : 'day');
          } catch (error) {}
        }

        if (themeToggle) {
          themeToggle.addEventListener('click', function () {
            setNight(root.dataset.paperTheme !== 'night');
          });
        }

        function setIntroOpen(isOpen) {
          if (!introPicker || !introToggle) return;
          introPicker.classList.toggle('open', isOpen);
          introToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        }

        if (introToggle) {
          introToggle.addEventListener('click', function () {
            setIntroOpen(!introPicker.classList.contains('open'));
          });
        }

        document.addEventListener('click', function (event) {
          if (introPicker && !introPicker.contains(event.target)) setIntroOpen(false);
        });

        function renderResults(query) {
          if (!searchResults) return;
          var items = [];
          try {
            items = JSON.parse(searchResults.dataset.items || '[]');
          } catch (error) {}

          var keyword = query.trim().toLowerCase();
          var matches = items.filter(function (item) {
            if (!keyword) return true;
            return [item.title, item.description, item.category, item.keywords]
              .join(' ')
              .toLowerCase()
              .includes(keyword);
          }).slice(0, 6);

          if (!matches.length) {
            searchResults.innerHTML = '<p class="search-empty">没有找到相关内容，换个关键词试试。</p>';
            return;
          }

          searchResults.innerHTML = matches.map(function (item) {
            return '<a href="' + item.href + '">' +
              '<span>' + item.category + '</span>' +
              '<strong>' + item.title + '</strong>' +
              '<p>' + item.description + '</p>' +
              '</a>';
          }).join('') + '<a class="search-all" href="' + searchResults.dataset.allArticles + '">浏览全部文章 →</a>';
        }

        function setSearchOpen(isOpen) {
          if (!searchOverlay) return;
          searchOverlay.classList.toggle('open', isOpen);
          searchOverlay.setAttribute('aria-hidden', isOpen ? 'false' : 'true');
          document.body.classList.toggle('search-open', isOpen);
          if (isOpen) {
            renderResults(searchInput ? searchInput.value : '');
            window.setTimeout(function () { if (searchInput) searchInput.focus(); }, 120);
          }
        }

        searchOpeners.forEach(function (button) {
          button.addEventListener('click', function () { setSearchOpen(true); });
        });
        searchClosers.forEach(function (button) {
          button.addEventListener('click', function () { setSearchOpen(false); });
        });
        if (searchInput) {
          searchInput.addEventListener('input', function () { renderResults(searchInput.value); });
        }

        document.addEventListener('keydown', function (event) {
          if (event.key === 'Escape') {
            setIntroOpen(false);
            setSearchOpen(false);
          }
        });

        var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        var revealItems = document.querySelectorAll('[data-reveal]');
        if (reducedMotion || !('IntersectionObserver' in window)) {
          revealItems.forEach(function (item) { item.classList.add('visible'); });
        } else {
          var observer = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
              if (!entry.isIntersecting) return;
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            });
          }, { threshold: 0.12 });
          revealItems.forEach(function (item) { observer.observe(item); });
        }
      })();
    </script>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --paper: #f8f4eb;
    --paper-soft: #fcfaf5;
    --paper-card: rgba(255, 253, 248, 0.88);
    --ink: #111c2e;
    --ink-soft: #5d6270;
    --line: rgba(82, 70, 53, 0.2);
    --line-strong: rgba(82, 70, 53, 0.34);
    --blue: #0667e8;
    --blue-soft: #55a5e4;
    --cyan: #35b8c2;
    --coral: #f06f45;
    --shadow: 0 18px 50px rgba(70, 55, 37, 0.09);
    --serif: "Songti SC", "STSong", "Noto Serif CJK SC", "Source Han Serif SC", Georgia, serif;
    --sans: Inter, "PingFang SC", "Microsoft YaHei", system-ui, sans-serif;
    --hand: "Kaiti SC", "STKaiti", KaiTi, var(--serif);
  }

  :root[data-paper-theme='night'] {
    color-scheme: dark;
    --paper: #171b22;
    --paper-soft: #20252d;
    --paper-card: rgba(35, 40, 48, 0.92);
    --ink: #f3eee3;
    --ink-soft: #b9b4aa;
    --line: rgba(235, 225, 207, 0.16);
    --line-strong: rgba(235, 225, 207, 0.3);
    --blue: #65a7ff;
    --blue-soft: #79bde8;
    --cyan: #58cbd0;
    --coral: #ff8e68;
    --shadow: 0 18px 50px rgba(0, 0, 0, 0.28);
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    background-color: var(--paper);
    background-image: var(--paper-texture);
    background-repeat: repeat;
    background-size: 900px auto;
    color: var(--ink);
    font-family: var(--serif);
    margin: 0;
    min-width: 320px;
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  :root[data-paper-theme='night'] body {
    background-blend-mode: multiply;
    background-image: none;
  }

  body.search-open {
    overflow: hidden;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button,
  input {
    font: inherit;
  }

  button {
    color: inherit;
  }

  .shell {
    margin: 0 auto;
    max-width: 1370px;
    padding-left: 44px;
    padding-right: 44px;
    width: 100%;
  }

  .paper-header {
    backdrop-filter: blur(14px);
    background: color-mix(in srgb, var(--paper-soft) 89%, transparent);
    border-bottom: 1px solid var(--line);
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .header-inner {
    align-items: center;
    display: grid;
    gap: 28px;
    grid-template-columns: auto 1fr auto;
    height: 84px;
    margin: 0 auto;
    max-width: 1470px;
    padding: 0 44px;
  }

  .paper-brand {
    align-items: center;
    display: inline-flex;
    gap: 16px;
    white-space: nowrap;
  }

  .paper-brand strong {
    font-size: 21px;
    letter-spacing: 0.01em;
  }

  .brand-mark {
    align-items: center;
    background: linear-gradient(145deg, #1567f2, #10b4b8);
    border-radius: 11px;
    box-shadow: 0 8px 18px rgba(20, 103, 232, 0.2);
    color: #fff;
    display: inline-flex;
    font-family: var(--sans);
    font-size: 22px;
    font-weight: 700;
    height: 44px;
    justify-content: center;
    width: 44px;
  }

  .paper-nav {
    align-items: stretch;
    display: flex;
    gap: clamp(22px, 2.7vw, 46px);
    height: 100%;
    justify-content: center;
  }

  .paper-nav a,
  .paper-nav button {
    align-items: center;
    background: none;
    border: 0;
    cursor: pointer;
    display: inline-flex;
    font-size: 16px;
    padding: 0;
