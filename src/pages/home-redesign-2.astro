  .paper-nav a:hover::after,
  .paper-nav button:hover::after,
  .paper-nav .active::after {
    transform: translateX(-50%) scaleX(1);
  }

  .paper-nav .active {
    color: var(--blue);
  }

  .header-actions {
    --home-index-height: 42px;
    --home-index-radius: 10px;
    --home-index-padding: 18px;
    --home-index-font-size: 15px;
    --home-index-bg: color-mix(in srgb, var(--paper-soft) 86%, transparent);
    --home-index-border: var(--line-strong);
    display: flex;
    gap: 12px;
  }

  .header-button {
    background: color-mix(in srgb, var(--paper-soft) 86%, transparent);
    border: 1px solid var(--line-strong);
    border-radius: 10px;
    cursor: pointer;
    font-size: 15px;
    min-height: 42px;
    padding: 0 18px;
    transition: border-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .header-button:hover {
    border-color: var(--blue);
    color: var(--blue);
    transform: translateY(-1px);
  }

  .intro-picker {
    position: relative;
  }

  .intro-menu {
    background: var(--paper-soft);
    border: 1px solid var(--line-strong);
    border-radius: 12px;
    box-shadow: var(--shadow);
    display: grid;
    gap: 3px;
    min-width: 160px;
    opacity: 0;
    padding: 7px;
    pointer-events: none;
    position: absolute;
    right: 0;
    top: calc(100% + 10px);
    transform: translateY(-5px);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .intro-picker.open .intro-menu {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .intro-menu a {
    border-radius: 8px;
    font-family: var(--sans);
    font-size: 14px;
    padding: 11px 12px;
  }

  .intro-menu a:hover {
    background: color-mix(in srgb, var(--blue) 9%, transparent);
    color: var(--blue);
  }

  .paper-hero {
    display: grid;
    gap: clamp(48px, 6vw, 92px);
    grid-template-columns: minmax(0, 1.62fr) minmax(360px, 0.86fr);
    padding-bottom: 62px;
    padding-top: 64px;
  }

  .hero-copy {
    padding: 20px 0 0 8px;
  }

  .hand-note {
    color: var(--coral);
    font-family: var(--hand);
    font-size: 20px;
    letter-spacing: 0.11em;
    margin: 0 0 25px;
    transform: rotate(-1.2deg);
  }

  .hero-copy h1 {
    font-size: clamp(55px, 5.25vw, 78px);
    font-weight: 700;
    letter-spacing: -0.045em;
    line-height: 1.26;
    margin: 0;
  }

  .hero-copy h1 span {
    display: inline-block;
    position: relative;
  }

  .hero-copy h1 span::after {
    background: var(--blue-soft);
    bottom: 2px;
    content: '';
    height: 3px;
    left: -8px;
    opacity: 0.55;
    position: absolute;
    transform: rotate(-0.7deg);
    width: calc(100% + 18px);
  }

  .hero-lead {
    color: var(--ink-soft);
    font-size: 19px;
    line-height: 1.85;
    margin: 31px 0 28px;
  }

  .hero-actions {
    align-items: center;
    display: flex;
    gap: 34px;
  }

  .primary-action {
    background: var(--blue);
    border: 1px solid var(--blue);
    border-radius: 6px;
    box-shadow: 0 11px 25px rgba(6, 103, 232, 0.18);
    color: #fff;
    display: inline-flex;
    font-size: 17px;
    justify-content: center;
    min-width: 146px;
    padding: 15px 26px;
    transition: box-shadow 0.24s ease, transform 0.24s ease;
  }

  .primary-action:hover {
    box-shadow: 0 15px 30px rgba(6, 103, 232, 0.25);
    transform: translateY(-2px);
  }

  .text-action,
  .small-link,
  .section-heading > a,
  .direction-card > a {
    color: var(--blue);
    font-family: var(--serif);
  }

  .text-action span,
  .small-link span,
  .section-heading > a span,
  .direction-card > a span {
    display: inline-block;
    transition: transform 0.2s ease;
  }

  .text-action:hover span,
  .small-link:hover span,
  .section-heading > a:hover span,
  .direction-card > a:hover span {
    transform: translateX(4px);
  }

  .recent-board {
    border-left: 1px solid var(--line-strong);
    padding: 8px 0 0 32px;
  }

  .recent-board h2 {
    font-family: var(--hand);
    font-size: 23px;
    font-weight: 500;
    letter-spacing: 0.08em;
    margin: 0;
    transform: rotate(-1.1deg);
  }

  .ink-stroke {
    background: var(--cyan);
