    grid-template-columns: repeat(4, minmax(0, 1fr));
    padding: 37px 25px 28px;
    position: relative;
  }

  .direction-board::before,
  .direction-board::after {
    background: color-mix(in srgb, var(--paper-soft) 80%, transparent);
    border: 1px solid var(--line);
    content: '';
    inset: 10px -14px -10px 12px;
    pointer-events: none;
    position: absolute;
    transform: rotate(0.35deg);
    z-index: -1;
  }

  .direction-board::after {
    inset: 18px 10px -16px -8px;
    transform: rotate(-0.25deg);
  }

  .direction-card {
    display: flex;
    min-height: 380px;
    flex-direction: column;
    padding: 0 24px;
  }

  .direction-card + .direction-card {
    border-left: 1px solid var(--line);
  }

  .direction-heading h2 {
    font-size: 23px;
    margin: 0 0 5px;
  }

  .direction-heading h2 span {
    color: var(--coral);
    margin-left: 6px;
  }

  .direction-practice .direction-heading h2 span {
    color: var(--cyan);
  }

  .direction-heading p {
    color: var(--ink-soft);
    font-size: 13px;
    margin: 0;
  }

  .paper-visual,
  .code-sheet,
  .sheet-preview {
    margin: 23px 0 20px;
  }

  .lined-note {
    background-image: var(--lined-paper);
    background-position: center;
    background-size: cover;
    color: #1e2734;
    font-family: var(--hand);
    min-height: 198px;
    padding: 42px 34px 30px;
    transform: rotate(-1.8deg);
  }

  .note-date {
    display: block;
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 0.12em;
    margin-bottom: 11px;
  }

  .lined-note p {
    font-size: 17px;
    line-height: 2.05;
    margin: 0;
  }

  .code-sheet {
    background: #111d2d;
    border: 1px solid #273b53;
