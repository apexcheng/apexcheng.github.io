    transform: rotate(-1.3deg);
    width: 106px;
  }

  .recent-item {
    display: grid;
    gap: 13px;
    grid-template-columns: 9px minmax(0, 1fr);
    padding: 17px 0 20px;
  }

  .recent-item + .recent-item {
    border-top: 1px solid var(--line);
  }

  .recent-dot {
    background: var(--cyan);
    border-radius: 50%;
    height: 8px;
    margin-top: 9px;
    width: 8px;
  }

  .recent-dot.coral {
    background: var(--coral);
  }

  .recent-title-row {
    align-items: start;
    display: grid;
    gap: 10px;
    grid-template-columns: minmax(0, 1fr) auto;
  }

  .recent-title-row h3 {
    font-size: 16px;
    line-height: 1.55;
    margin: 0;
  }

  .recent-title-row time {
    color: var(--ink-soft);
    font-family: var(--sans);
    font-size: 11px;
    padding-top: 4px;
  }

  .recent-item p {
    color: var(--ink-soft);
    display: -webkit-box;
    font-size: 13px;
    line-height: 1.65;
    margin: 6px 0 0;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .small-link {
    display: inline-flex;
    font-size: 14px;
    margin: 4px 0 0 17px;
  }

  .direction-section {
    padding-bottom: 105px;
    position: relative;
  }

  .section-hand-label {
    display: inline-block;
    font-family: var(--hand);
    font-size: 22px;
    letter-spacing: 0.1em;
    margin: 0 0 -9px 36px;
