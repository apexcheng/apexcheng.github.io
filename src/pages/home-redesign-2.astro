    font-family: var(--sans);
    font-size: 11px;
    justify-content: space-between;
  }

  .series-folder h3 {
    font-size: 26px;
    line-height: 1.45;
    margin: 31px 0 15px;
  }

  .series-folder p {
    color: var(--ink-soft);
    font-size: 14px;
    line-height: 1.8;
    margin: 0;
  }

  .folder-action {
    bottom: 31px;
    color: var(--blue);
    font-size: 14px;
    left: 33px;
    position: absolute;
  }

  .folder-action i {
    display: inline-block;
    font-style: normal;
    margin-left: 5px;
    transition: transform 0.2s ease;
  }

  .series-folder:hover .folder-action i {
    transform: translateX(4px);
  }

  .cyan-note {
    color: var(--cyan);
  }

  .lab-list {
    border-top: 1px solid var(--line-strong);
  }

  .lab-row {
    align-items: center;
    border-bottom: 1px solid var(--line);
    display: grid;
    gap: 28px;
    grid-template-columns: 46px minmax(0, 1.4fr) 280px 24px;
    min-height: 168px;
    padding: 24px 18px;
    transition: background-color 0.24s ease, padding-left 0.24s ease;
  }

  .lab-row:hover {
    background: color-mix(in srgb, var(--paper-card) 58%, transparent);
    padding-left: 28px;
  }

  .lab-index {
    color: var(--ink-soft);
    font-family: var(--sans);
    font-size: 12px;
  }

  .lab-copy > span {
    color: var(--cyan);
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 0.08em;
  }

  .lab-copy h3 {
    font-size: 23px;
    margin: 8px 0 7px;
  }

  .lab-copy p {
    color: var(--ink-soft);
    font-size: 13px;
    line-height: 1.65;
    margin: 0;
  }

  .lab-swatch {
    align-items: end;
    background: #eef7f7;
    border: 1px solid #c7dcdd;
    display: flex;
    gap: 16px;
    height: 92px;
    justify-content: center;
    padding: 17px;
  }

  .lab-swatch i {
    background: var(--cyan);
    height: 30%;
    width: 28px;
  }

  .lab-swatch i:nth-child(2) {
    height: 72%;
  }

  .lab-swatch i:nth-child(3) {
    height: 48%;
  }

  .lab-swatch.coral {
    background: #fbf0ea;
    border-color: #ecd2c3;
  }

  .lab-swatch.coral i {
    background: var(--coral);
  }

  .lab-swatch.ink {
    background: #172333;
    border-color: #2c4259;
  }

  .lab-swatch.ink i {
    background: #77baf1;
  }

  .lab-arrow {
    color: var(--blue);
    font-size: 19px;
  }

  .archive-list {
    display: grid;
  }

  .archive-row {
    align-items: center;
    border-top: 1px solid var(--line);
    display: grid;
    gap: 28px;
    grid-template-columns: 42px minmax(250px, 0.9fr) minmax(0, 1.15fr) 94px 20px;
    min-height: 122px;
    padding: 20px 12px;
    transition: color 0.2s ease, padding-left 0.2s ease;
  }

  .archive-row:last-child {
    border-bottom: 1px solid var(--line);
  }

  .archive-row:hover {
    color: var(--blue);
    padding-left: 22px;
  }

  .archive-no,
  .archive-row time {
    color: var(--ink-soft);
    font-family: var(--sans);
    font-size: 11px;
  }

  .archive-category {
    color: var(--coral);
    font-family: var(--sans);
    font-size: 11px;
  }

  .archive-row h3 {
    font-size: 19px;
    margin: 6px 0 0;
  }

  .archive-row p {
    color: var(--ink-soft);
    display: -webkit-box;
    font-size: 13px;
    line-height: 1.65;
    margin: 0;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .closing-section {
    align-items: center;
    border-top: 1px solid var(--line);
    display: flex;
    justify-content: space-between;
    padding-bottom: 112px;
    padding-top: 112px;
  }

  .closing-section p {
    font-family: var(--hand);
    font-size: clamp(28px, 3vw, 42px);
    margin: 0;
    transform: rotate(-0.7deg);
  }

  .closing-section a {
    background: var(--blue);
    border-radius: 5px;
    color: #fff;
    padding: 14px 22px;
  }

  .paper-footer {
    border-top: 1px solid var(--line);
    color: var(--ink-soft);
    font-family: var(--sans);
    font-size: 12px;
  }

  .paper-footer .shell {
    align-items: center;
    display: flex;
    gap: 26px;
    justify-content: space-between;
    min-height: 90px;
  }

  .search-overlay {
    inset: 0;
    opacity: 0;
    pointer-events: none;
    position: fixed;
    transition: opacity 0.24s ease;
    z-index: 100;
  }

  .search-overlay.open {
    opacity: 1;
    pointer-events: auto;
  }

  .search-backdrop {
    backdrop-filter: blur(7px);
    background: rgba(25, 28, 34, 0.35);
    border: 0;
    inset: 0;
    position: absolute;
    width: 100%;
  }

  .search-sheet {
    background-color: var(--paper-soft);
    background-image: var(--paper-texture);
    border: 1px solid var(--line-strong);
    box-shadow: 0 28px 90px rgba(32, 24, 14, 0.24);
    left: 50%;
    max-height: min(760px, calc(100vh - 80px));
    max-width: 760px;
    overflow: auto;
    padding: 34px;
    position: absolute;
    top: 40px;
    transform: translate(-50%, -14px);
    transition: transform 0.24s ease;
    width: calc(100% - 40px);
  }

  .search-overlay.open .search-sheet {
    transform: translate(-50%, 0);
  }

  .search-head {
    align-items: start;
    display: flex;
    justify-content: space-between;
  }

  .search-head .hand-note {
    font-size: 15px;
    margin: 0 0 5px;
  }

  .search-head h2 {
    font-size: 31px;
    margin: 0;
  }

  .search-head button {
    background: transparent;
    border: 1px solid var(--line-strong);
    cursor: pointer;
    padding: 8px 13px;
  }

  .search-sheet input {
    background: color-mix(in srgb, var(--paper-card) 85%, transparent);
    border: 0;
    border-bottom: 2px solid var(--ink);
    color: var(--ink);
    font-family: var(--serif);
    font-size: 19px;
    margin: 28px 0 16px;
    outline: none;
    padding: 15px 4px;
    width: 100%;
  }

  .search-results {
    display: grid;
  }

  .search-results > a:not(.search-all) {
    border-bottom: 1px solid var(--line);
    display: grid;
    gap: 4px;
    padding: 17px 4px;
  }

  .search-results > a:not(.search-all):hover strong {
    color: var(--blue);
  }

  .search-results span {
    color: var(--coral);
    font-family: var(--sans);
    font-size: 10px;
  }

  .search-results strong {
    font-size: 17px;
  }

  .search-results p {
    color: var(--ink-soft);
    font-size: 12px;
    line-height: 1.55;
    margin: 0;
  }

  .search-all {
    color: var(--blue);
    padding: 19px 4px 4px;
  }

  .search-empty {
    padding: 35px 4px;
  }

  .js [data-reveal] {
    opacity: 0;
    transform: translateY(18px);
    transition: opacity 0.46s ease, transform 0.46s ease;
  }

  .js [data-reveal].visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 1120px) {
    .header-inner {
      gap: 18px;
      grid-template-columns: auto 1fr;
    }

    .paper-nav {
      gap: 24px;
      justify-content: flex-end;
    }

    .header-actions {
      display: none;
    }

    .paper-hero {
      gap: 42px;
      grid-template-columns: minmax(0, 1.35fr) minmax(320px, 0.9fr);
    }

    .hero-copy h1 {
      font-size: clamp(48px, 5.5vw, 64px);
    }

    .direction-board {
      gap: 0;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .direction-card {
      min-height: 390px;
      padding: 24px 34px;
    }

    .direction-card + .direction-card {
      border-left: 0;
