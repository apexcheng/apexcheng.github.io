    box-shadow: 0 8px 17px rgba(12, 24, 40, 0.18);
    color: #e2e8f0;
    min-height: 198px;
    overflow: hidden;
    padding: 16px 12px;
    transform: rotate(0.3deg);
  }

  .code-sheet pre {
