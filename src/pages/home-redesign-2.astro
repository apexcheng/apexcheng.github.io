    position: relative;
    transform: rotate(-1.2deg);
    z-index: 2;
  }

  .section-hand-label::after {
    background: var(--cyan);
    bottom: 0;
    content: '';
    height: 2px;
    left: 0;
    opacity: 0.62;
    position: absolute;
    transform: rotate(0.8deg);
    width: 178px;
  }

  .direction-board {
    background: color-mix(in srgb, var(--paper-soft) 88%, transparent);
