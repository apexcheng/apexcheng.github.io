  .line-no {
    color: #64748b;
    display: inline-block;
    margin-right: 9px;
    text-align: right;
    width: 13px;
  }

  .code-blue {
    color: #7dd3fc;
  }

  .code-green {
    color: #bef264;
  }

  .grid-note {
    background-image: var(--grid-paper);
    background-position: center;
    background-size: cover;
    color: #242832;
    font-family: var(--hand);
    min-height: 198px;
    padding: 30px 35px;
    transform: rotate(1.1deg);
  }

  .grid-note strong {
    display: block;
    font-size: 17px;
    margin-bottom: 10px;
  }

  .grid-note ol {
    font-size: 13px;
    line-height: 1.75;
    margin: 0;
    padding-left: 20px;
  }

  .sheet-preview {
    background: #fffdf8;
    border: 1px solid #d8d4ca;
    box-shadow: 0 8px 19px rgba(74, 57, 34, 0.08);
    color: #263144;
    min-height: 198px;
    padding: 16px;
    transform: rotate(-0.5deg);
  }

  .mini-table {
    border: 1px solid #cfd5dc;
    font-family: var(--sans);
    font-size: 8px;
  }

  .mini-table > div {
    display: grid;
    grid-template-columns: 1.6fr 0.85fr 0.6fr;
  }

  .mini-table span,
  .mini-table b {
    border-right: 1px solid #d9dee4;
    border-top: 1px solid #d9dee4;
    font-weight: 500;
    padding: 5px 4px;
  }

  .mini-table .table-head span {
    background: #f1f4f7;
    border-top: 0;
    font-weight: 700;
  }

  .mini-chart {
    align-items: end;
    border-bottom: 1px solid #d7dce3;
    display: flex;
    gap: 11px;
    height: 70px;
    justify-content: center;
    margin: 13px 8px 0;
  }

  .mini-chart i {
    background: var(--cyan);
    height: var(--value);
    width: 15px;
  }

  .direction-card > a {
    font-size: 14px;
    margin-top: auto;
  }

  .series-section,
  .lab-section,
  .archive-section {
    border-top: 1px solid var(--line);
    padding-bottom: 112px;
    padding-top: 96px;
  }

  .section-heading {
    align-items: end;
    display: flex;
    justify-content: space-between;
    margin-bottom: 48px;
  }

  .section-heading .hand-note {
    font-size: 18px;
    margin-bottom: 12px;
  }

  .section-heading h2 {
    font-size: clamp(34px, 3vw, 46px);
    letter-spacing: -0.03em;
    margin: 0;
  }

  .section-heading > a {
    font-size: 15px;
    padding-bottom: 7px;
  }

  .series-grid {
    display: grid;
    gap: 24px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .series-folder {
    background: color-mix(in srgb, var(--paper-card) 93%, transparent);
    border: 1px solid var(--line);
    box-shadow: 0 14px 40px rgba(75, 58, 36, 0.07);
    min-height: 330px;
    padding: 42px 33px 31px;
    position: relative;
    transition: box-shadow 0.26s ease, transform 0.26s ease;
  }

  .series-folder::before {
    background: var(--coral);
    content: '';
    height: 3px;
    left: 0;
    position: absolute;
    right: 0;
    top: 0;
  }

  .series-folder.cyan::before {
    background: var(--cyan);
  }

  .series-folder.blue::before {
    background: var(--blue);
  }

  .series-folder:hover {
    box-shadow: 0 20px 48px rgba(75, 58, 36, 0.12);
    transform: translateY(-4px) rotate(-0.2deg);
  }

  .folder-tab {
    background: var(--paper-card);
    border: 1px solid var(--line);
    border-bottom: 0;
    font-family: var(--hand);
    font-size: 14px;
    left: 26px;
    padding: 7px 18px;
    position: absolute;
    top: -32px;
