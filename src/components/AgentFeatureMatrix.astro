---
type Tone = 'purple' | 'blue' | 'orange' | 'green' | 'pink';
type IconName = keyof typeof icons;

const icons = {
  flask: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 3h6M10 3v5.4L5.8 16.1A3.2 3.2 0 0 0 8.6 21h6.8a3.2 3.2 0 0 0 2.8-4.9L14 8.4V3"/><path d="M8.3 15h7.4"/></svg>`,
  arrows: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 7h10l-3-3M17 17H7l3 3M17 7 6 18"/></svg>`,
  document: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 3h7l4 4v14H7z"/><path d="M14 3v5h5M9 12h6M9 16h6"/></svg>`,
  code: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="m9 7-5 5 5 5M15 7l5 5-5 5M13 5l-2 14"/></svg>`,
  users: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M16 19v-1.4c0-1.8-1.8-3.1-4-3.1s-4 1.3-4 3.1V19"/><circle cx="12" cy="8" r="3"/><path d="M20 19v-1.2c0-1.4-1.1-2.5-2.8-2.9M17 6.2a2.4 2.4 0 0 1 0 4.6M4 19v-1.2c0-1.4 1.1-2.5 2.8-2.9M7 6.2a2.4 2.4 0 0 0 0 4.6"/></svg>`,
  book: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 5.5A3.5 3.5 0 0 1 8.5 4H20v16H8.5A3.5 3.5 0 0 0 5 21.5z"/><path d="M5 5.5A3.5 3.5 0 0 0 1.5 4H4v16H1.5A3.5 3.5 0 0 1 5 21.5zM5 5.5v16"/></svg>`,
} as const;

interface FeatureItem {
  icon: IconName;
  eyebrow: string;
  title: string;
  description: string;
  tags: string[];
  tone: Tone;
  highlight?: boolean;
}

const features: FeatureItem[] = [
  {
    icon: 'flask',
    eyebrow: 'PERSISTENT AGENT',
    title: '常驻型个人助手 / 研究助手',
    description: '基于长期记忆机制，自动保存环境事实、项目约定与研究偏好，支持跨会话连续理解与任务执行，形成个性化、让 Agent 成为真正的长期伙伴。',
    tags: ['长期研究建模', '跨域记忆', '多语言支持'],
    tone: 'purple',
    highlight: true,
  },
  {
    icon: 'arrows',
    eyebrow: 'MULTI-ENTRY',
    title: '多入口统一助理',
    description: '同一个 Agent 可从 CLI、Telegram、Discord 等多入口接入，“start on one, pick up on another”——在电脑上做的活，出门后手机继续。',
    tags: ['CLI 终端', 'Telegram 机器人', '跨设备同步 Bot'],
    tone: 'blue',
  },
  {
    icon: 'document',
    eyebrow: 'AUTOMATION',
    title: '自动化信息 / 商报机器人',
    description: '内建 Cron 调度、Web Search、Deliver / Email、Message Delivery、工作流组合、定时简报、自动总结，推送至 Telegram 或 Discord。',
    tags: ['AI 商讯简报', 'GitHub 监控', '日报 / 周报'],
    tone: 'orange',
  },
  {
    icon: 'code',
    eyebrow: 'CODE ORCHESTRATION',
    title: '代码与工程工作流编排',
    description: '作为你的工程级 Copadic Codex、Codex、OpenCode 等专业 Coding Agent，自动执行任务、审查代码变更、复杂改造等场景。',
    tags: ['代码重构', '工程自动化', '持续集成'],
    tone: 'green',
  },
  {
    icon: 'users',
    eyebrow: 'MULTI-PROFILE',
    title: '多角色、多 Profile Agent 系统',
    description: '同时扮演工程师、产品经理、研究员、提示工程师、API 设计师等角色，针对复杂任务组建团队，输出结构化 Agent 方案，支持多专家协作。',
    tags: ['角色协同', '多 Agent 团队', '专业分工输出'],
    tone: 'pink',
  },
  {
    icon: 'book',
    eyebrow: 'KNOWLEDGE',
    title: '知识库 / 记忆系统',
    description: '通过 Obsidian、Notion、Vector DB 构建结构化知识 Workspace，支持全文检索、语义召回，沉淀组织与个人的长期有效知识资产。',
    tags: ['文档索引', '向量检索', '持久记忆'],
    tone: 'blue',
  },
];
---

<section class="agent-feature-matrix" aria-label="Agent 功能矩阵">
  {features.map((item) => (
    <article class:list={["agent-feature-card", `tone-${item.tone}`, item.highlight && 'is-highlighted']}>
      <div class="agent-feature-icon" set:html={icons[item.icon]} />
      <span class="agent-feature-eyebrow">{item.eyebrow}</span>
      <h3>{item.title}</h3>
      <p>{item.description}</p>
      <div class="agent-feature-tags" aria-label="功能标签">
        {item.tags.map((tag) => <span>{tag}</span>)}
      </div>
    </article>
  ))}
</section>

<style>
  .agent-feature-matrix {
    display: grid;
    gap: 34px 44px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin: 30px 0;
    padding: 8px 0 4px;
  }

  .agent-feature-card {
    border-radius: 14px;
    min-height: 292px;
    padding: 18px 24px 24px;
    position: relative;
  }

  .agent-feature-card.is-highlighted {
    background:
      linear-gradient(var(--paper), var(--paper)) padding-box,
      linear-gradient(135deg, #ff785a, #f7d94d) border-box;
    border: 2px solid transparent;
    box-shadow: 0 20px 46px rgba(17, 24, 39, 0.06);
  }

  .agent-feature-icon {
    align-items: center;
    background: var(--tone-gradient);
    border-radius: 13px;
    box-shadow: 0 14px 30px var(--tone-shadow);
    color: #fff;
    display: inline-flex;
    height: 46px;
    justify-content: center;
    margin-bottom: 26px;
    width: 46px;
  }

  .agent-feature-icon :global(svg) {
    fill: none;
    height: 26px;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.9;
    width: 26px;
  }

  .agent-feature-eyebrow {
    color: var(--tone);
    display: block;
    font-size: 12px;
    font-weight: 840;
    letter-spacing: 0.04em;
    margin-bottom: 16px;
  }

  .agent-feature-card h3 {
    color: var(--ink);
    font-size: clamp(20px, 2.3vw, 26px);
    letter-spacing: -0.03em;
    line-height: 1.18;
    margin: 0 0 18px;
  }

  .agent-feature-card p {
    color: var(--muted);
    font-size: 15px;
    line-height: 1.9;
    margin: 0;
  }

  .agent-feature-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 14px 24px;
    margin-top: 26px;
  }

  .agent-feature-tags span {
    color: var(--tone);
    font-size: 14px;
    font-weight: 780;
    white-space: nowrap;
  }

  .tone-purple {
    --tone: #6d28d9;
    --tone-gradient: linear-gradient(135deg, #7c3aed, #a855f7);
    --tone-shadow: rgba(124, 58, 237, 0.24);
  }

  .tone-blue {
    --tone: #2563eb;
    --tone-gradient: linear-gradient(135deg, #2563eb, #22c6ee);
    --tone-shadow: rgba(37, 99, 235, 0.22);
  }

  .tone-orange {
    --tone: #ea580c;
    --tone-gradient: linear-gradient(135deg, #f97316, #f59e0b);
    --tone-shadow: rgba(249, 115, 22, 0.24);
  }

  .tone-green {
    --tone: #059669;
    --tone-gradient: linear-gradient(135deg, #10b981, #14b8a6);
    --tone-shadow: rgba(16, 185, 129, 0.22);
  }

  .tone-pink {
    --tone: #e11d48;
    --tone-gradient: linear-gradient(135deg, #f43f5e, #ec4899);
    --tone-shadow: rgba(244, 63, 94, 0.23);
  }

  html[data-theme='dark'] .agent-feature-card.is-highlighted {
    background:
      linear-gradient(var(--paper), var(--paper)) padding-box,
      linear-gradient(135deg, rgba(255, 120, 90, 0.9), rgba(247, 217, 77, 0.78)) border-box;
  }

  @media (max-width: 1120px) {
    .agent-feature-matrix {
      gap: 28px;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .agent-feature-matrix {
      grid-template-columns: 1fr;
    }

    .agent-feature-card {
      min-height: auto;
      padding: 22px;
    }
  }
</style>
