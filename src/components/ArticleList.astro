---
import { withBase } from '../utils/paths';
import { getSeriesMeta } from '../data/series';
import { formatPostDate } from '../utils/dates';

const { posts, hideVisualLab = false, hideSeries = false } = Astro.props;
---

<div class="article-list" data-article-list>
  {posts.map((post) => (
    <article
      class="article-list-item"
      data-article-item
      data-category={post.data.category}
      data-series={post.data.series ?? ''}
      data-published-at={post.data.date.valueOf()}
      data-updated-at={(post.data.updated ?? post.data.date).valueOf()}
      hidden={(hideVisualLab && post.data.category === '视觉实验室') || (hideSeries && post.data.series)}
    >
      <div>
        <small><a href={withBase(`/articles/category/${encodeURIComponent(post.data.category)}/`)}>{post.data.category}</a></small>
        <h2><a href={withBase(`/articles/${post.slug}/`)}>{post.data.title}</a></h2>
        <p>{post.data.description}</p>
        {post.data.series && (
          <p class="article-series-meta">
            <a href={withBase(`/series/${post.data.series}/`)}>
              系列 · {getSeriesMeta(post.data.series)?.title} · 第 {post.data.seriesOrder} 篇
            </a>
          </p>
        )}
        <div class="chips">
          {post.data.tags.map((tag) => <a href={withBase(`/articles/tag/${encodeURIComponent(tag)}/`)}>{tag}</a>)}
        </div>
      </div>
      <time datetime={post.data.date.toISOString()}>
        {formatPostDate(post.data.date)}
        <span>阅读约 {post.data.minutes} 分钟</span>
      </time>
    </article>
  ))}
</div>
